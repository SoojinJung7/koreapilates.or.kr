# ─────────────────────────────────────────────────────────────
# KPA 통합 로그인(SSO) 환경변수 — 이 파일을 .env 로 복사해 값을 채우세요.
# PUBLIC_ 접두사는 "클라이언트(브라우저)에 노출되는 값"이라는 뜻입니다.
# (anon key 는 원래 공개용이라 노출되어도 안전합니다. service_role 키는 절대 넣지 마세요.)
#
# 운영에서는 이 값들을 GitHub 저장소 Settings > Secrets and variables > Actions 에
# 등록하면 배포 워크플로우(deploy.yml)가 빌드 시 주입합니다.
# ─────────────────────────────────────────────────────────────

# 앱(KPA 교육생 앱)과 "동일한" Supabase 프로젝트여야 세션이 공유됩니다.
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...앱과_같은_anon_key

# 앱과 홈페이지가 세션 쿠키를 공유할 상위 도메인. 반드시 앞에 점(.)!
# 로컬 개발 중에는 비워두세요(현재 호스트에만 저장 = 정상).
PUBLIC_AUTH_COOKIE_DOMAIN=.koreapilates.or.kr

# 홈페이지 '로그인' 버튼이 사용자를 보낼 앱 로그인 페이지.
# 앱은 여기서 구글 OAuth를 처리하고 ?next= 로 받은 주소로 되돌려보내야 합니다.
PUBLIC_APP_LOGIN_URL=https://student.koreapilates.or.kr/login
