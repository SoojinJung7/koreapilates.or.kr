---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteMeta } from '../data/nav.js';
import { withBase } from '../utils/url.js';

const { title, description } = Astro.props;
const pageTitle = title ? `${title} | ${siteMeta.short}` : siteMeta.title;
const pageDesc = description || siteMeta.description;
const pretendard = withBase('/fonts/PretendardVariable.woff2');
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="icon" href={siteMeta.favicon} />
    <style is:inline set:html={`
      @font-face {
        font-family: 'Pretendard';
        font-weight: 45 920;
        font-style: normal;
        font-display: swap;
        src: url('${pretendard}') format('woff2-variations');
      }
    `}></style>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
