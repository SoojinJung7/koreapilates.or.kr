---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url.js';

// 원본 오시는길 정보 그대로
const kakaoChat = 'https://pf.kakao.com/_vIRDxl/chat';
const mapEmbed =
  'https://maps.google.com/maps?q=' +
  encodeURIComponent('성남시 분당구 내정로 58') +
  '&hl=ko&z=16&output=embed';

const info = [
  {
    en: 'ADDRESS',
    title: '주소',
    lines: [
      '성남시 분당구 내정로 58',
      '3.5층 교육장 / 4층 아카데미사무실',
      '정자역 1번출구 도보 6분',
      "정자역 3번출구 앞 220번, '정자2동 행정복지센터' 정류장 바로 앞",
    ],
  },
  {
    en: 'CONTACT',
    title: '상담 / 문의',
    lines: ['031-728-7724', '카카오톡으로 상세한 상담이 가능합니다.'],
  },
  {
    en: 'HOURS',
    title: '교육장 이용안내',
    lines: [
      '교육/수련시간 무료주차 지원',
      '교육장 무료개방',
      '평일 8시 - 23시',
      '주말 9시 - 21시',
      '(1, 3, 5주차 일요일 휴관)',
    ],
  },
];
---
<BaseLayout title="오시는길">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">DIRECTIONS</p>
      <h1>오시는 길</h1>
      <p class="page-hero-sub">
        국내 최대 시설을 통해 회원들에게 쾌적한 교육환경 및 훈련공간을 제공합니다.
      </p>
    </div>
  </section>

  <!-- MAP -->
  <section class="map-section">
    <div class="map-frame">
      <iframe
        src={mapEmbed}
        title="사)대한필라테스협회 아카데미 위치 지도"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <!-- INFO CARDS -->
  <section class="section info">
    <div class="wrap">
      <div class="info-grid">
        {info.map((c) => (
          <article class="info-card">
            <p class="info-en">{c.en}</p>
            <h2>{c.title}</h2>
            <ul>
              {c.lines.map((l) => <li>{l}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section address-cta">
    <div class="wrap">
      <h2>더 궁금한 점이 있으신가요?</h2>
      <p>카카오톡으로 상세한 상담이 가능합니다.</p>
      <div class="address-cta-btns">
        <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">카카오톡 상담</a>
        <a class="btn" href="tel:031-728-7724">031-728-7724</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--kp-maroon);
    color: #fff;
    text-align: center;
    padding-block: clamp(70px, 12vw, 130px);
  }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink);
    font-size: clamp(15px, 2vw, 19px);
    margin-top: 16px;
    max-width: 680px;
    margin-inline: auto;
  }

  /* MAP */
  .map-section { padding: 0; }
  .map-frame {
    width: 100%;
    aspect-ratio: 16 / 7;
    min-height: 320px;
    background: var(--kp-sage);
  }
  .map-frame iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* INFO CARDS */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 48px);
  }
  .info-card {
    border-top: 3px solid var(--kp-maroon);
    padding-top: 26px;
  }
  .info-en {
    font-family: var(--font-display);
    letter-spacing: 0.18em;
    color: var(--kp-sage);
    font-size: 13px;
    margin: 0 0 8px;
  }
  .info-card h2 { color: var(--kp-maroon); margin: 0 0 18px; font-size: clamp(21px, 2.6vw, 26px); }
  .info-card ul { list-style: none; margin: 0; padding: 0; }
  .info-card li {
    color: var(--kp-olive);
    font-size: clamp(15px, 1.7vw, 16px);
    line-height: 1.7;
    padding-left: 0;
    margin-bottom: 6px;
  }

  /* CTA */
  .address-cta { background: var(--kp-ink); color: #fff; text-align: center; }
  .address-cta h2 { color: #fff; margin-bottom: 12px; }
  .address-cta p { color: var(--kp-pink); margin-bottom: 28px; }
  .address-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .address-cta .btn { border-color: var(--kp-cream); color: #fff; }
  .address-cta .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .address-cta .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .address-cta .btn--filled:hover { background: #fff; }

  @media (max-width: 820px) {
    .info-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
