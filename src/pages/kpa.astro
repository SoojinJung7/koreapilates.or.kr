---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url.js';

// 협회 특징과 장점
const strengths = [
  '국내 민간 필라테스 자격증 발급 협회',
  '기구 필라테스 포함 통합 교육 과정 운영',
  '해부학, 실습, 티칭을 포함한 체계적인 커리큘럼',
  '분당 본원에서 단일 교육 시스템으로 운영',
  '약 200~250시간 이상의 교육 과정 구성',
  '소수 정예 수업으로 밀도 높은 교육 가능',
  '실습 및 로그북 기반의 체계적인 트레이닝',
];

// 본 과정이 필요한 분
const audience = [
  '필라테스를 처음 배우고 지도자가 되고 싶은 입문자',
  '해부학 기반으로 체계적인 교육을 원하시는 분',
  '실습 중심의 교육을 통해 티칭 능력을 키우고자 하는 분',
  '안정적인 환경에서 꾸준한 배움과 성장을 원하시는 분',
];

// 자주 묻는 질문 (FAQ)
const faqs = [
  {
    q: '국내 필라테스 교육기관 중, 왜 KPA일까요?',
    blocks: [
      {
        t: 'A. 실전 중심의 독보적인 인프라',
        d: '교육의 체계성과 실습 비중을 고려한다면 단연 KPA입니다. 전문 필라테스 시설이 완비된 본원 환경에서 전체 지도자 과정이 오프라인 실전 중심으로 밀착 진행되기에, 기초부터 탄탄히 다지고 싶은 입문자에게 가장 안정적인 선택지가 되어줍니다.',
      },
      {
        t: 'B. 교육 전용 앱을 통한 고품격 소통 서비스',
        d: "KPA는 교육생과 교육 강사 간의 긴밀한 교류를 위해 'KPA 교육 전용 애플리케이션'을 제공합니다. 이를 통해 강의실 밖에서도 언제 어디서나 고품질의 소통과 밀착 피드백이 가능하여, 학습 효율을 극대화할 수 있습니다.",
      },
      {
        t: 'C. 국내외를 아우르는 압도적인 사후 교육 시스템',
        d: '자격증 취득이 끝이 아닙니다. 졸업 후에도 지속적인 성장을 지원하는 탄탄한 심화 과정을 운영하고 있습니다. KPA의 수준 높은 커리큘럼은 본 협회 회원뿐만 아니라 타 협회 강사 분들까지 찾아와 함께 수료할 만큼 대외적으로 깊은 공신력을 인정받고 있습니다. 이에 더해 에릭 프랭클린과 같은 세계적인 운동 지도자를 초빙하는 ‘해외 초청 세미나’를 정기적으로 개최하여, 교육생들이 글로벌 트렌드에 발맞춘 세계적 수준의 역량을 갖출 수 있도록 전폭적으로 지원합니다.',
      },
      {
        t: 'D. 몰입도를 극대화하는 6인 소수정예 시스템',
        d: "KPA는 교육생 한 분 한 분의 완벽한 성장을 위해 오직 '6인 소수정예' 밀착 교육만을 고집합니다. 정원이 적은 만큼 대기 시간 없이 본인의 연습 시간을 여유롭게 확보할 수 있으며, 실제 현장과 다름없는 풍부한 티칭 실습 기회가 보장됩니다. 교육생 간의 상호 티칭 직후, 담당 교육 강사가 그 자리에서 즉각적으로 정밀한 피드백을 제공하는 유기적인 시스템을 통해 단 한 순간의 낭비도 없이 완벽하게 실력을 마스터할 수 있습니다.",
      },
    ],
  },
  {
    q: '국제 자격증 대신 국내 자격증도 괜찮을까요?',
    blocks: [
      {
        t: 'A. 네, 전혀 문제없습니다.',
        d: "국내 자격증만으로도 강사 활동은 충분히 가능하며, 중요한 것은 실제 현장에서 통하는 '실습과 티칭 경험'입니다. 이미 본원의 수많은 수료생들이 KPA 자격증 하나만으로 국내를 넘어 해외에서까지 전문 강사로 활발히 활동하며 그 역량을 증명하고 있습니다. 결국 어디서 시작하든 실전에 강한 탄탄한 실력을 키우는 것이 핵심입니다.",
      },
    ],
  },
  {
    q: '필라테스 지도자 과정에서 가장 중요한 것은 무엇인가요?',
    blocks: [
      {
        t: "A. '1. 탄탄한 해부학적 이해', '2. 충분한 실습 시간', '3. 실제 강사 활동 연계' — 세 가지가 핵심입니다.",
        d: '대한필라테스협회(KPA)는 이러한 실습·티칭 중심의 교육을 최우선으로 두며, 기초부터 체계적인 배움을 원하는 분들에게 가장 훌륭한 선택지입니다. 특히 정규 교육 시간 외에도 본원의 전문 시설을 활용해 자유롭게 연습할 수 있도록 공간을 지원하여, 수강생분들이 부족함 없이 실력을 갈고닦을 수 있도록 돕습니다.',
      },
    ],
  },
];
---
<BaseLayout title="협회소개">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">ABOUT KPA</p>
      <h1>협회소개</h1>
      <p class="page-hero-sub">국내 최초 사단법인 필라테스 교육기관</p>
    </div>
  </section>

  <!-- 협회 소개 -->
  <section class="section intro">
    <div class="wrap intro-wrap">
      <p class="lead">
        사단법인 대한필라테스협회는 우리나라 최초의 사단법인 필라테스 교육기관으로
        필라테스 운동법을 국내에 알리고 홍보해왔습니다.
      </p>
      <p>
        해부학, 생리학, 필라테스 동작들의 이점 및 특징을 철저히 교육하여 단순히 운동법을
        가르치는 것이 아닌, 사람마다 다른 체형들에 알맞은 동작들을 정확히 알고 선정하여
        가르칩니다. 또한 필라테스 지도자과정 교육을 통해 필라테스의 대중화에 기여하기 위해
        노력해 오고 있습니다.
      </p>
      <p>
        본 협회는 2003년 12월 호주 필라테스협회(APMA, Australian Pilates Method
        Association)의 퍼넬러 피레이티의 방문으로 국내최초 필라테스 세미나를 개최한 후 이를
        기반으로 대한필라테스협회가 설립되었습니다. 그 후 활발한 교육활동을 하고 있으며,
        협회 내 자체적인 교육 프로그램을 개발하고 국내외 전문가를 초빙한 다양한 세미나를
        개최함으로써 경쟁력 있는 지도자를 육성하고자 노력하고 있습니다.
      </p>
    </div>
  </section>

  <!-- 협회장 인사말 -->
  <section class="section greeting">
    <div class="wrap">
      <p class="eyebrow">GREETINGS</p>
      <h2>대한필라테스협회장 인사말</h2>
      <div class="greeting-body">
        <p class="greeting-hi">안녕하세요. 이학박사 정승만입니다.</p>
        <p>
          대한필라테스협회는 여러 사람들이 필라테스를 통해 기회를 얻고, 또 자신과 타인의
          건강을 지킬 수 있기를 바라는 마음으로 시작되었습니다.
        </p>
        <p>
          대한필라테스협회는 필라테스 운동지도를 위해 꼭 필요한 “필라테스 운동원리”,
          “필라테스 운동방법”, “필라테스 기구 사용방법”, “해부학” 등의 교육과정 교재를
          개발하고 관련 전문가를 통한 교육 및 자격 검증으로 지도자과정 강사를 국제 필라테스
          연맹인 PMA(Pilates Method Alliance)의 가이드라인에 맞추어 육성하고 있습니다.
          필라테스 지도자교육 후 “취업” 및 “지속적인 교육”도 가능합니다.
        </p>
        <p>
          필라테스를 통해 여러분들의 꿈을 현실로 이루시고 여러 사람의 건강과 활력을 책임져줄
          수 있는 기회를 잡으시기 바랍니다.
        </p>
        <p class="greeting-sign">사단법인 대한필라테스협회장 &nbsp;정승만</p>
      </div>
    </div>
  </section>

  <!-- 특징과 장점 -->
  <section class="section strengths">
    <div class="wrap">
      <p class="eyebrow">WHY KPA</p>
      <h2>대한필라테스협회(KPA) 특징과 장점</h2>
      <p class="strengths-sub">
        대한필라테스협회(KPA)는 국내에서 필라테스 지도자 교육 과정을 운영하는 민간 협회 중
        하나로, 기초부터 체계적인 교육을 원하는 입문자에게 적합한 교육 시스템을 제공합니다.
      </p>
      <ul class="strength-grid">
        {strengths.map((s, i) => (
          <li class="strength-card">
            <span class="strength-num">{String(i + 1).padStart(2, '0')}</span>
            <p>{s}</p>
          </li>
        ))}
      </ul>
      <p class="strengths-note">
        전 교육 과정은 현장 실전 역량을 위해 오프라인으로만 진행됩니다.
      </p>
    </div>
  </section>

  <!-- 본 과정이 필요한 분 -->
  <section class="section audience">
    <div class="wrap">
      <p class="eyebrow">FOR YOU</p>
      <h2>본 과정이 필요한 분</h2>
      <ul class="audience-list">
        {audience.map((a) => (
          <li>{a}</li>
        ))}
      </ul>
      <div class="audience-note">
        <p class="audience-note-title">✔️ 참고사항</p>
        <ul>
          <li>교육은 분당 정자 본원에서만 진행됩니다.</li>
          <li>타 유사 협회와의 오인 및 혼동을 주의하세요. (KPA 공식 마크 확인)</li>
          <li>교육 과정에는 해부학, 실습, 티칭이 포함됩니다.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq">
    <div class="wrap">
      <p class="eyebrow">FAQ</p>
      <h2>자주 묻는 질문</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary><span class="faq-q">Q.</span> {f.q}</summary>
            <div class="faq-answer">
              {f.blocks.map((b) => (
                <div class="faq-block">
                  <p class="faq-block-t">{b.t}</p>
                  <p class="faq-block-d">{b.d}</p>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section about-cta">
    <div class="wrap">
      <h2>KPA와 함께 지도자의 길을 시작하세요</h2>
      <div class="about-cta-btns">
        <a class="btn btn--filled" href={withBase('/coursedate')}>지도자과정 교육일정</a>
        <a class="btn" href={withBase('/curriculum')}>커리큘럼 보기</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--kp-maroon);
    color: #fff;
    text-align: center;
    padding-block: clamp(70px, 12vw, 130px);
  }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub { color: var(--kp-pink); font-size: clamp(16px, 2vw, 20px); margin-top: 14px; }

  /* INTRO */
  .intro { text-align: center; }
  .intro-wrap { max-width: 860px; }
  .intro .lead {
    font-size: clamp(20px, 2.6vw, 27px);
    color: var(--kp-maroon);
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 28px;
  }
  .intro p { color: var(--kp-olive); }

  /* GREETING */
  .greeting { background: var(--kp-cream); text-align: center; }
  .greeting h2 { color: var(--kp-maroon); }
  .greeting-body { max-width: 820px; margin: 34px auto 0; text-align: left; }
  .greeting-hi { font-size: clamp(19px, 2.4vw, 24px); font-weight: 600; color: var(--kp-ink); margin-bottom: 22px; }
  .greeting-body p { color: var(--kp-olive); }
  .greeting-sign { text-align: right; margin-top: 30px; color: var(--kp-maroon); font-weight: 600; letter-spacing: 0.04em; }

  /* STRENGTHS */
  .strengths { text-align: center; }
  .strengths h2 { color: var(--kp-maroon); }
  .strengths-sub { max-width: 760px; margin: 0 auto 44px; color: var(--kp-olive); }
  .strength-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px;
    text-align: left;
  }
  .strength-card {
    background: #fff; border: 1px solid var(--kp-line);
    padding: 26px 24px; display: flex; gap: 18px; align-items: center;
    transition: border-color .3s, transform .3s;
  }
  .strength-card:hover { border-color: var(--kp-sage); transform: translateY(-3px); }
  .strength-num { font-family: var(--font-display); font-size: 26px; color: var(--kp-sage); line-height: 1; font-weight: 700; }
  .strength-card p { margin: 0; font-size: 16px; color: var(--kp-ink); }
  .strengths-note { margin-top: 34px; color: var(--kp-maroon); font-weight: 600; font-size: 15px; }

  /* AUDIENCE */
  .audience { background: var(--kp-olive); color: #fff; }
  .audience h2 { color: #fff; }
  .audience .eyebrow { color: var(--kp-cream); }
  .audience-list { list-style: none; padding: 0; margin: 0 0 40px; display: grid; gap: 12px; max-width: 780px; }
  .audience-list li {
    position: relative; padding: 16px 20px 16px 52px;
    background: rgba(255,255,255,0.08); border-radius: 4px; font-size: 16px;
  }
  .audience-list li::before {
    content: '✓'; position: absolute; left: 20px; top: 50%; transform: translateY(-50%);
    color: var(--kp-cream); font-weight: 700;
  }
  .audience-note { border: 1px solid rgba(255,255,255,0.2); padding: 26px 28px; max-width: 780px; border-radius: 4px; }
  .audience-note-title { margin: 0 0 12px; font-weight: 700; color: var(--kp-cream); }
  .audience-note ul { margin: 0; padding-left: 20px; color: rgba(255,255,255,0.85); }
  .audience-note li { font-size: 15px; margin-bottom: 6px; }

  /* FAQ */
  .faq { text-align: center; }
  .faq h2 { color: var(--kp-maroon); margin-bottom: 40px; }
  .faq-list { max-width: 880px; margin: 0 auto; text-align: left; display: grid; gap: 14px; }
  .faq-item { border: 1px solid var(--kp-line); background: #fff; border-radius: 4px; overflow: hidden; }
  .faq-item summary {
    list-style: none; cursor: pointer; padding: 22px 26px;
    font-size: clamp(16px, 2vw, 19px); font-weight: 600; color: var(--kp-ink);
    display: flex; gap: 12px; align-items: baseline; position: relative;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+'; margin-left: auto; font-size: 24px; color: var(--kp-sage);
    font-weight: 400; transition: transform .25s;
  }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item[open] summary { background: var(--kp-cream); }
  .faq-q { color: var(--kp-sage); font-family: var(--font-display); font-weight: 700; }
  .faq-answer { padding: 8px 26px 26px; }
  .faq-block { margin-top: 20px; }
  .faq-block:first-child { margin-top: 4px; }
  .faq-block-t { font-weight: 600; color: var(--kp-maroon); margin: 0 0 6px; }
  .faq-block-d { margin: 0; color: var(--kp-olive); font-size: 15.5px; }

  /* CTA */
  .about-cta { background: var(--kp-ink); color: #fff; text-align: center; }
  .about-cta h2 { color: #fff; margin-bottom: 30px; }
  .about-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .about-cta .btn { border-color: var(--kp-cream); color: #fff; }
  .about-cta .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .about-cta .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .about-cta .btn--filled:hover { background: #fff; }

  @media (max-width: 600px) {
    .greeting-sign { text-align: left; }
  }
</style>
