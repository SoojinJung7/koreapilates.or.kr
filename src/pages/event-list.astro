---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, img } from '../utils/url.js';

const kakaoChat = 'https://pf.kakao.com/_vIRDxl/chat';

// 페이지 대표 이미지 (워크샵 현장)
const heroImg = '6f7ec1_a83cbb7373c448a18e9b390df45c6eb1~mv2.jpeg';

// 예정된 워크샵 / 세미나 일정
const events = [
  {
    poster: '6f7ec1_ebe863dd061248698be60363ee3c9256~mv2.webp',
    title: 'Franklin method®의 창시자, 에릭 프랭클린이 온다!',
    en: 'Eric Franklin visits Korea! International Workshop',
    date: '2025년 11월 28일(금) - 29일(토)',
    place: '경기도 성남시 분당구 내정로 58',
    region: '성남시, 대한민국',
    lead:
      "Franklin Method®의 창시자이자 세계적 베스트셀러 『Dynamic Alignment Through Imagery』의 저자, 에릭 프랭클린(Eric Franklin)이 한국을 찾습니다.",
    tags: ['#Communication', '#Anatomy', '#Embodiment', '#Creative Cueing', '#Unlock Your Potential'],
    sessions: [
      {
        no: 'Workshop 1.',
        name: 'Pelvic Power',
        date: '2025.11.28',
        time: '9:30 AM – 12:45 PM (195분)',
        price: '300,000 KRW',
      },
      {
        no: 'Workshop 2.',
        name: 'Inspired Shoulder',
        date: '2025.11.28',
        time: '2:15 PM – 5:30 PM (195분)',
        price: '300,000 KRW',
      },
      {
        no: 'Workshop 3.',
        name: '1 Day Certification',
        date: '2025.11.29',
        time: 'Franklin Method® Embodied Cueing',
        price: '수료 시 자격증 발급',
      },
    ],
    packages: [
      {
        tag: 'Early Bird Package',
        body: '11월 1일까지! 정가 1,200,000 KRW → 3개 워크샵 전체 900,000 KRW',
      },
      {
        tag: 'Certification Package',
        body: 'Embodied Cueing 자격과정 참가자 한정 : Workshop 1 또는 2를 50% 할인!',
      },
    ],
  },
];
---
<BaseLayout title="워크샵/세미나 신청">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <img class="page-hero-bg" src={img(heroImg)} alt="" aria-hidden="true" />
    <div class="wrap page-hero-inner">
      <p class="eyebrow">WORKSHOP &amp; SEMINAR SCHEDULE</p>
      <h1>세미나 / 워크샵 일정</h1>
      <p class="page-hero-sub">
        KPA 협회에서는 졸업 이후에도 배움을 이어나갈 수 있도록<br />
        수준 높은 교육 컨텐츠를 제공합니다.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section intro">
    <div class="wrap">
      <div class="intro-inner">
        <p class="intro-body">
          KPA 협회에서는 졸업 이후에도 배움을 이어나갈 수 있도록 수준 높은 교육
          컨텐츠를 제공합니다. 다양한 워크숍 지도자과정을 수료한 졸업생이라면 누구나
          프로그램에 참여할 수 있으며, 이를 통해 지속적인 배움과 성장을 위한 환경을
          제공합니다. 교육과정 수강 시 할인 혜택을 받을 수 있습니다.
        </p>
        <p class="intro-note">
          *교육생의 경우, 졸업생을 대상으로 한 일부 세미나는 참가 신청이 불가합니다.
        </p>
      </div>
    </div>
  </section>

  <!-- SCHEDULE -->
  <section class="section schedule">
    <div class="wrap">
      <div class="schedule-head">
        <p class="eyebrow">Workshop / Global Seminar Schedule</p>
        <h2>워크샵 / 글로벌 세미나 일정</h2>
      </div>

      {events.map((e) => (
        <article class="event-card">
          <div class="event-media">
            <img src={img(e.poster)} alt={e.title} loading="lazy" />
          </div>
          <div class="event-body">
            <p class="event-en">{e.en}</p>
            <h3>{e.title}</h3>
            <ul class="event-meta">
              <li><span>일정</span>{e.date}</li>
              <li><span>장소</span>{e.place}</li>
              <li><span>지역</span>{e.region}</li>
            </ul>
            <p class="event-lead">{e.lead}</p>

            <div class="event-tags">
              {e.tags.map((t) => (
                <span class="event-tag">{t}</span>
              ))}
            </div>

            <div class="session-grid">
              {e.sessions.map((s) => (
                <div class="session-card">
                  <p class="session-no">{s.no}</p>
                  <h4>{s.name}</h4>
                  <p class="session-date">{s.date}</p>
                  <p class="session-time">{s.time}</p>
                  <p class="session-price">{s.price}</p>
                </div>
              ))}
            </div>

            <ul class="package-list">
              {e.packages.map((p) => (
                <li>
                  <span class="package-tag">{p.tag}</span>
                  <span class="package-body">{p.body}</span>
                </li>
              ))}
            </ul>

            <div class="event-actions">
              <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">세부 정보 &amp; 신청</a>
              <a class="btn" href={withBase('/workshop-seminar')}>워크샵/세미나 안내</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section el-cta">
    <div class="wrap">
      <p class="eyebrow">JOIN US</p>
      <h2>참가 신청 및 문의</h2>
      <p>일정·비용 등 자세한 내용은 카카오톡 채널로 편하게 문의해 주세요.</p>
      <div class="el-cta-btns">
        <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">카카오톡 상담</a>
        <a class="btn" href={withBase('/graduates-seminar')}>졸업생 세미나 보기</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    color: #fff;
    text-align: center;
    padding-block: clamp(80px, 14vw, 150px);
    overflow: hidden;
    background: var(--kp-maroon);
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.32;
    filter: saturate(0.9);
  }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink);
    font-size: clamp(15px, 2vw, 19px);
    margin-top: 16px;
    line-height: 1.7;
  }

  /* INTRO */
  .intro-inner { max-width: 860px; margin: 0 auto; text-align: center; }
  .intro-body { color: var(--kp-olive); font-size: clamp(15px, 1.9vw, 17px); line-height: 1.95; margin: 0 0 16px; }
  .intro-note { color: var(--kp-maroon); font-weight: 700; font-size: clamp(13px, 1.6vw, 15px); margin: 0; }

  /* SCHEDULE */
  .schedule { background: var(--kp-cream); }
  .schedule-head { text-align: center; margin-bottom: clamp(28px, 4vw, 44px); }
  .schedule-head h2 { color: var(--kp-maroon); font-size: clamp(26px, 4vw, 42px); margin: 6px 0 0; }

  .event-card {
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(28, 16, 18, 0.09);
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: stretch;
  }
  .event-media { background: #f1f1f1; }
  .event-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .event-body { padding: clamp(26px, 3.5vw, 44px) clamp(24px, 3.5vw, 44px) clamp(26px, 3.5vw, 44px) 0; }

  .event-en {
    font-family: var(--font-display);
    color: var(--kp-sage);
    font-weight: 800;
    letter-spacing: 0.03em;
    font-size: 14px;
    margin: 0 0 6px;
  }
  .event-body h3 { color: var(--kp-maroon); font-size: clamp(21px, 2.8vw, 30px); margin: 0 0 20px; line-height: 1.3; }

  .event-meta { list-style: none; margin: 0 0 20px; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .event-meta li { color: var(--kp-ink); font-size: 15px; line-height: 1.6; }
  .event-meta span {
    display: inline-block;
    min-width: 52px;
    margin-right: 12px;
    color: var(--kp-sage);
    font-weight: 800;
    font-size: 13px;
  }

  .event-lead { color: var(--kp-olive); font-size: clamp(14px, 1.7vw, 16px); line-height: 1.85; margin: 0 0 20px; }

  .event-tags { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 24px; }
  .event-tag {
    background: rgba(122, 105, 94, 0.14);
    color: var(--kp-olive);
    font-size: 13px;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 999px;
  }

  .session-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin: 0 0 24px;
  }
  .session-card {
    background: #fbf7ef;
    border: 1px solid var(--kp-line);
    border-radius: 14px;
    padding: 18px 16px;
  }
  .session-no {
    font-family: var(--font-display);
    color: var(--kp-sage);
    font-weight: 800;
    font-size: 12px;
    margin: 0 0 4px;
  }
  .session-card h4 { color: var(--kp-maroon); font-size: 17px; margin: 0 0 10px; }
  .session-date { color: var(--kp-ink); font-weight: 700; font-size: 13.5px; margin: 0 0 4px; }
  .session-time { color: var(--kp-olive); font-size: 13px; line-height: 1.5; margin: 0 0 8px; }
  .session-price { color: var(--kp-maroon); font-weight: 700; font-size: 14px; margin: 0; }

  .package-list { list-style: none; margin: 0 0 28px; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .package-list li {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
    background: rgba(214, 192, 195, 0.18);
    border-left: 3px solid var(--kp-maroon);
    border-radius: 0 10px 10px 0;
    padding: 12px 16px;
  }
  .package-tag {
    background: var(--kp-maroon);
    color: var(--kp-cream);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.03em;
    padding: 4px 11px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .package-body { color: var(--kp-ink); font-size: 14px; line-height: 1.6; }

  .event-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* CTA */
  .el-cta { background: var(--kp-ink); color: #fff; text-align: center; }
  .el-cta .eyebrow { color: var(--kp-pink); }
  .el-cta h2 { color: #fff; margin: 6px 0 12px; font-size: clamp(26px, 4vw, 40px); }
  .el-cta p { color: var(--kp-pink); margin-bottom: 28px; line-height: 1.8; }
  .el-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .el-cta .btn { border-color: var(--kp-cream); color: #fff; }
  .el-cta .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .el-cta .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .el-cta .btn--filled:hover { background: #fff; }

  @media (max-width: 900px) {
    .event-card { grid-template-columns: 1fr; gap: 0; }
    .event-media { aspect-ratio: 4 / 5; }
    .event-body { padding: clamp(24px, 5vw, 32px); }
    .session-grid { grid-template-columns: 1fr; }
  }
</style>
