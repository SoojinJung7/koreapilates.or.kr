---
<BaseLayout title="강사소개">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">FACULTY</p>
      <h1>강사소개</h1>
      <p class="page-hero-sub">
        필라테스 지도자과정 교육을 통해 필라테스의 대중화에 기여하기 위해 노력하고 있습니다.
      </p>
    </div>
  </section>

  <!-- 강사진 -->
  <section class="section faculty">
    <div class="wrap">
      <div class="faculty-list">
        {faculty.map((f, i) => (
          <article class="prof" id={`prof-${i + 1}`}>
            <div class="prof-photo">
              <img src={img(f.photo)} alt={`${f.name} ${f.role}`} loading="lazy" />
            </div>
            <div class="prof-info">
              <header class="prof-head">
                <h2>
                  {f.name}<span class="prof-role">{f.role}</span>
                </h2>
                {f.badge && <span class="prof-badge">{f.badge}</span>}
              </header>
              {f.sections.map((sec) => (
                <div class="prof-section">
                  <h3 class="prof-section-title">{sec.label}</h3>
                  <ul class="prof-items">
                    {sec.items.map((it) => (
                      <li>{it}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section faculty-cta">
    <div class="wrap">
      <h2>KPA의 강사진과 함께 성장하세요</h2>
      <div class="faculty-cta-btns">
        <a class="btn btn--filled" href={withBase('/coursedate')}>지도자과정 교육일정</a>
        <a class="btn" href={withBase('/curriculum')}>커리큘럼 보기</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--kp-maroon);
    color: #fff;
    text-align: center;
    padding-block: clamp(70px, 12vw, 130px);
  }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink); font-size: clamp(15px, 2vw, 19px);
    margin-top: 14px; max-width: 640px; margin-inline: auto;
  }

  /* FACULTY LIST */
  .faculty-list { display: grid; gap: clamp(48px, 8vw, 90px); }
  .prof {
    display: grid;
    grid-template-columns: minmax(0, 360px) minmax(0, 1fr);
    gap: clamp(28px, 5vw, 60px);
    align-items: start;
  }
  .prof-photo {
    position: sticky; top: 110px;
    border: 1px solid var(--kp-line);
    background: var(--kp-cream);
    overflow: hidden;
  }
  .prof-photo img { display: block; width: 100%; height: auto; }

  .prof-head {
    display: flex; align-items: baseline; flex-wrap: wrap; gap: 14px;
    padding-bottom: 18px; margin-bottom: 26px;
    border-bottom: 2px solid var(--kp-sage);
  }
  .prof-head h2 {
    margin: 0; color: var(--kp-maroon);
    font-size: clamp(26px, 3.4vw, 34px);
    display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;
  }
  .prof-role {
    font-size: clamp(14px, 1.7vw, 17px);
    color: var(--kp-olive); font-weight: 600;
  }
  .prof-badge {
    font-family: var(--font-display); letter-spacing: 0.04em;
    font-size: 13px; font-weight: 700; color: #fff;
    background: var(--kp-sage); padding: 6px 12px; border-radius: 999px;
  }

  .prof-section { margin-bottom: 26px; }
  .prof-section:last-child { margin-bottom: 0; }
  .prof-section-title {
    font-size: 15px; color: var(--kp-olive);
    margin: 0 0 12px; font-weight: 700; letter-spacing: 0.02em;
  }
  .prof-items { list-style: none; padding: 0; margin: 0; display: grid; gap: 9px; }
  .prof-items li {
    position: relative; padding-left: 20px;
    color: var(--kp-ink); font-size: 15.5px; line-height: 1.55;
  }
  .prof-items li::before {
    content: ''; position: absolute; left: 4px; top: 10px;
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--kp-pink);
  }

  /* CTA */
  .faculty-cta { background: var(--kp-ink); color: #fff; text-align: center; }
  .faculty-cta h2 { color: #fff; margin-bottom: 30px; }
  .faculty-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .faculty-cta .btn { border-color: var(--kp-cream); color: #fff; }
  .faculty-cta .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .faculty-cta .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .faculty-cta .btn--filled:hover { background: #fff; }

  @media (max-width: 820px) {
    .prof { grid-template-columns: 1fr; gap: 24px; }
    .prof-photo { position: static; max-width: 360px; }
  }
</style>
