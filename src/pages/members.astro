---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, img } from '../utils/url.js';

const kakaoChat = 'https://pf.kakao.com/_vIRDxl/chat';

// 페이지 대표 이미지
const heroImg = '6f7ec1_bc66e70244be420aa1fb98353cc2528b~mv2.jpeg';

// 지역 필터 (검색 UI - 겉모습)
const regions = ['전체', '서울', '경기·인천', '강원', '충청', '전라', '경상', '제주'];

// 인증 등급 안내
const grades = [
  {
    name: '지도자 자격 과정',
    desc: 'KPA 지도자과정을 이수하고 인증 시험에 합격한 정회원입니다.',
  },
  {
    name: '심화 과정 수료',
    desc: '리포머·캐딜락 등 기구 심화과정을 추가로 이수한 인증 회원입니다.',
  },
  {
    name: 'NCPT 국제공인',
    desc: 'NCPT 국제공인 자격증을 취득한 글로벌 인증 지도자입니다.',
  },
];

// 승인된 회원 미리보기 (회원 로그인 후 전체 열람)
const members = [
  { name: '김○○', grade: 'NCPT 국제공인', region: '서울 · 강남' },
  { name: '이○○', grade: '심화 과정 수료', region: '경기 · 분당' },
  { name: '박○○', grade: '지도자 자격 과정', region: '서울 · 마포' },
  { name: '최○○', grade: 'NCPT 국제공인', region: '부산 · 해운대' },
  { name: '정○○', grade: '심화 과정 수료', region: '인천 · 송도' },
  { name: '한○○', grade: '지도자 자격 과정', region: '대전 · 유성' },
];
---
<BaseLayout title="인증 회원 찾기">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <img class="page-hero-bg" src={img(heroImg)} alt="" aria-hidden="true" />
    <div class="wrap page-hero-inner">
      <p class="eyebrow">MEMBERS</p>
      <h1>인증 회원 찾기</h1>
      <p class="page-hero-sub">
        KPA 인증 지도자를 지역별로 찾아보세요.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section intro">
    <div class="wrap">
      <div class="intro-inner">
        <p class="intro-body">
          이 페이지는 KPA 지도자과정을 이수하고 협회의 인증을 받은
          <strong>승인된 회원</strong>을 소개하는 공간입니다.
          검증된 KPA 인증 지도자를 지역과 자격 등급으로 찾아보실 수 있습니다.
        </p>
        <p class="intro-note">*회원 전체 프로필 열람은 로그인 후 이용하실 수 있습니다.</p>
      </div>
    </div>
  </section>

  <!-- SEARCH -->
  <section class="section search">
    <div class="wrap">
      <p class="eyebrow">Search</p>
      <h2>회원 검색</h2>
      <form class="search-box" role="search" onsubmit="return false;">
        <div class="search-field">
          <label for="m-name">이름</label>
          <input id="m-name" type="text" placeholder="지도자 이름을 입력하세요" disabled />
        </div>
        <div class="search-field">
          <label for="m-region">지역</label>
          <select id="m-region" disabled>
            {regions.map((r) => <option>{r}</option>)}
          </select>
        </div>
        <button class="btn btn--filled" type="button" disabled>🔒 검색</button>
      </form>
      <p class="search-note">*회원 검색 기능은 로그인 후 제공됩니다.</p>
    </div>
  </section>

  <!-- GRADES -->
  <section class="section grades">
    <div class="wrap">
      <p class="eyebrow">Grade</p>
      <h2>인증 등급 안내</h2>
      <div class="grade-grid">
        {grades.map((g) => (
          <article class="grade-card">
            <h3>{g.name}</h3>
            <p>{g.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MEMBER LIST -->
  <section class="section board">
    <div class="wrap">
      <div class="board-head">
        <div>
          <p class="eyebrow">Directory</p>
          <h2>승인된 회원</h2>
          <p class="board-desc">아래는 인증 회원 미리보기입니다. 전체 프로필은 로그인 후 확인하실 수 있습니다.</p>
        </div>
        <div class="board-auth">
          <a class="btn" href={kakaoChat} target="_blank" rel="noopener">로그인 ㅣ 회원가입</a>
        </div>
      </div>

      <div class="board-locked" role="region" aria-label="인증 회원 목록">
        <div class="member-grid">
          {members.map((m) => (
            <article class="member-card">
              <div class="member-avatar" aria-hidden="true">
                <img src={img('6f7ec1_e7a958c2e04f47a29cf69927afbd169b~mv2.png')} alt="" />
              </div>
              <h3>{m.name}</h3>
              <p class="member-grade"><span class="tag">{m.grade}</span></p>
              <p class="member-region">{m.region}</p>
              <button class="btn btn--sm" type="button" disabled aria-label="회원 전용 프로필">🔒 프로필 보기</button>
            </article>
          ))}
        </div>

        <div class="board-gate">
          <p class="gate-lock" aria-hidden="true">🔒</p>
          <p class="gate-title">회원 전용 정보입니다</p>
          <p class="gate-body">로그인 후 인증 회원의 전체 프로필을 확인하실 수 있습니다.</p>
          <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">로그인 ㅣ 회원가입</a>
        </div>
      </div>
    </div>
  </section>

  <!-- GUIDE -->
  <section class="section guide">
    <div class="wrap">
      <div class="guide-inner">
        <p class="eyebrow">Notice</p>
        <h2>이용 안내</h2>
        <p class="guide-body">
          인증 회원 등록은 KPA 지도자과정 이수 후 협회의 승인 절차를 거쳐 진행됩니다.<br />
          회원 등록 및 프로필 관련 문의는 카카오채널로 연락 주시기 바랍니다.
        </p>
        <div class="guide-actions">
          <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">카카오톡 상담</a>
          <a class="btn" href={withBase('/curriculum')}>지도자과정 알아보기</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    color: #fff;
    text-align: center;
    padding-block: clamp(80px, 14vw, 150px);
    overflow: hidden;
    background: var(--kp-maroon);
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.32;
    filter: saturate(0.9);
  }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink);
    font-size: clamp(15px, 2vw, 19px);
    margin-top: 16px;
    line-height: 1.7;
  }

  /* INTRO */
  .intro-inner { max-width: 860px; margin: 0 auto; text-align: center; }
  .intro-body { color: var(--kp-olive); font-size: clamp(15px, 1.9vw, 17px); line-height: 1.95; margin: 0 0 16px; }
  .intro-body strong { color: var(--kp-maroon); }
  .intro-note { color: var(--kp-maroon); font-weight: 700; font-size: clamp(13px, 1.6vw, 15px); margin: 0; }

  /* SEARCH */
  .search { background: var(--kp-cream); }
  .search .eyebrow { text-align: center; }
  .search h2 { color: var(--kp-maroon); text-align: center; font-size: clamp(26px, 4vw, 42px); margin: 6px 0 clamp(24px, 3.5vw, 36px); }
  .search-box {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 760px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 18px;
    padding: clamp(20px, 3vw, 30px);
    box-shadow: 0 12px 30px rgba(28, 16, 18, 0.08);
  }
  .search-field { display: flex; flex-direction: column; gap: 8px; flex: 1 1 200px; text-align: left; }
  .search-field label { color: var(--kp-olive); font-weight: 700; font-size: 13.5px; }
  .search-field input, .search-field select {
    border: 1px solid var(--kp-line);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 15px;
    font-family: inherit;
    color: var(--kp-ink);
    background: #fff;
  }
  .search-field input:disabled, .search-field select:disabled { background: #faf8f4; cursor: not-allowed; }
  .search-box .btn { flex: 0 0 auto; }
  .btn[disabled] { opacity: 0.6; cursor: not-allowed; }
  .search-note { color: var(--kp-maroon); font-weight: 700; text-align: center; font-size: 14px; margin: 18px 0 0; }

  /* GRADES */
  .grades .eyebrow { text-align: center; }
  .grades h2 { color: var(--kp-maroon); text-align: center; font-size: clamp(26px, 4vw, 42px); margin: 6px 0 clamp(24px, 3.5vw, 40px); }
  .grade-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 2.5vw, 28px);
  }
  .grade-card {
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 18px;
    padding: clamp(24px, 3vw, 34px);
    box-shadow: 0 12px 30px rgba(28, 16, 18, 0.08);
  }
  .grade-card h3 { color: var(--kp-maroon); font-size: clamp(18px, 2.4vw, 22px); margin: 0 0 12px; }
  .grade-card p { color: var(--kp-olive); font-size: 15px; line-height: 1.8; margin: 0; }

  /* BOARD */
  .board { background: var(--kp-cream); }
  .board-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: clamp(16px, 2.5vw, 24px);
  }
  .board-head h2 { color: var(--kp-maroon); font-size: clamp(26px, 4vw, 42px); margin: 6px 0 0; }
  .board-desc { color: var(--kp-olive); font-size: 15px; margin: 8px 0 0; }

  .board-locked { position: relative; }
  .member-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2.4vw, 26px);
  }
  .member-card {
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 18px;
    padding: clamp(22px, 2.6vw, 30px);
    text-align: center;
    box-shadow: 0 12px 30px rgba(28, 16, 18, 0.06);
  }
  .member-avatar {
    width: 92px;
    height: 92px;
    margin: 0 auto 16px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--kp-cream);
    border: 1px solid var(--kp-line);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .member-avatar img { width: 78%; height: 78%; object-fit: contain; opacity: 0.85; }
  .member-card h3 { color: var(--kp-ink); font-size: clamp(17px, 2.2vw, 20px); margin: 0 0 10px; }
  .member-grade { margin: 0 0 8px; }
  .member-region { color: var(--kp-sage); font-size: 14px; margin: 0 0 16px; }
  .tag {
    display: inline-block;
    background: var(--kp-cream);
    color: var(--kp-maroon);
    font-weight: 700;
    font-size: 12.5px;
    padding: 4px 11px;
    border-radius: 999px;
  }
  .btn--sm { padding: 8px 16px; font-size: 13px; }

  /* Locked overlay */
  .board-gate {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-align: center;
    padding: 24px;
    background: linear-gradient(to bottom, rgba(250,246,240,0.5) 0%, rgba(250,246,240,0.94) 46%);
    backdrop-filter: blur(2.5px);
    border-radius: 8px;
  }
  .gate-lock { font-size: 40px; margin: 0; }
  .gate-title { color: var(--kp-maroon); font-weight: 800; font-size: clamp(18px, 2.6vw, 24px); margin: 0; }
  .gate-body { color: var(--kp-olive); font-size: 15px; margin: 0 0 8px; line-height: 1.7; }

  /* GUIDE */
  .guide { background: var(--kp-ink); color: #fff; text-align: center; }
  .guide-inner { max-width: 760px; margin: 0 auto; }
  .guide .eyebrow { color: var(--kp-pink); }
  .guide h2 { color: #fff; margin: 6px 0 12px; font-size: clamp(24px, 4vw, 38px); }
  .guide-body { color: var(--kp-pink); margin-bottom: 28px; line-height: 1.8; }
  .guide-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .guide .btn { border-color: var(--kp-cream); color: #fff; }
  .guide .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .guide .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .guide .btn--filled:hover { background: #fff; }

  @media (max-width: 900px) {
    .grade-grid { grid-template-columns: 1fr; }
    .member-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .member-grid { grid-template-columns: 1fr; }
    .search-box .btn { width: 100%; }
  }
</style>
