---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, img } from '../utils/url.js';

const kakaoChat = 'https://pf.kakao.com/_vIRDxl/chat';

// 페이지 대표 이미지
const heroImg = '6f7ec1_85c0b305476c4b92943d1b5415ef6ff4f000.jpg';

// 자료게시판 카테고리 (회원 전용)
const categories = [
  {
    name: '교육자료',
    desc: '지도자과정 수업에서 사용하는 교재·강의자료·실습 영상 등을 내려받을 수 있습니다.',
  },
  {
    name: '수료증 발급',
    desc: '과정을 이수한 교육생은 수료증 및 관련 증빙 서류를 다운로드할 수 있습니다.',
  },
  {
    name: '공지·서식',
    desc: '협회 공지사항과 신청서·동의서 등 각종 서식 자료를 확인할 수 있습니다.',
  },
];

// 게시판 목록 (미리보기용 - 회원 로그인 후 열람)
const posts = [
  { title: '지도자과정 매트 실습 자료집', cat: '교육자료', date: '2024.09.02' },
  { title: '리포머 응용 동작 정리 (PDF)', cat: '교육자료', date: '2024.08.19' },
  { title: '2024년 하반기 수료증 발급 안내', cat: '공지·서식', date: '2024.08.05' },
  { title: '해부학 기초 강의 노트', cat: '교육자료', date: '2024.07.22' },
  { title: '수강 신청서 · 개인정보 동의서 양식', cat: '공지·서식', date: '2024.07.10' },
];
---
<BaseLayout title="자료게시판">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <img class="page-hero-bg" src={img(heroImg)} alt="" aria-hidden="true" />
    <div class="wrap page-hero-inner">
      <p class="eyebrow">FILE SHARE</p>
      <h1>자료게시판</h1>
      <p class="page-hero-sub">
        교육자료 외 수료증 다운로드가 가능합니다.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section intro">
    <div class="wrap">
      <div class="intro-inner">
        <p class="intro-body">
          KPA 자료게시판은 지도자과정 교육생과 졸업생을 위한 회원 전용 공간입니다.
          수업 교재와 강의자료, 수료증, 각종 공지·서식을 한곳에서 확인하고
          내려받을 수 있습니다.
        </p>
        <p class="intro-note">*자료 열람 및 다운로드는 로그인 후 이용하실 수 있습니다.</p>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="section cats">
    <div class="wrap">
      <p class="eyebrow">Categories</p>
      <h2>자료 구분</h2>
      <div class="cat-grid">
        {categories.map((c) => (
          <article class="cat-card">
            <h3>{c.name}</h3>
            <p>{c.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BOARD -->
  <section class="section board">
    <div class="wrap">
      <div class="board-head">
        <div>
          <p class="eyebrow">Board</p>
          <h2>게시글</h2>
          <p class="board-desc">아래에서 자료를 확인하세요. 다운로드는 로그인 후 이용 가능합니다.</p>
        </div>
        <div class="board-auth">
          <a class="btn" href={kakaoChat} target="_blank" rel="noopener">로그인 ㅣ 회원가입</a>
        </div>
      </div>

      <div class="board-locked" role="region" aria-label="자료게시판 목록">
        <table class="board-table">
          <thead>
            <tr>
              <th class="col-title">제목</th>
              <th class="col-cat">구분</th>
              <th class="col-date">작성일</th>
              <th class="col-file">파일</th>
            </tr>
          </thead>
          <tbody>
            {posts.map((p) => (
              <tr>
                <td class="col-title">{p.title}</td>
                <td class="col-cat"><span class="tag">{p.cat}</span></td>
                <td class="col-date">{p.date}</td>
                <td class="col-file">
                  <button class="btn btn--sm" type="button" disabled aria-label="회원 전용 다운로드">🔒 다운로드</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>

        <div class="board-gate">
          <p class="gate-lock" aria-hidden="true">🔒</p>
          <p class="gate-title">회원 전용 자료입니다</p>
          <p class="gate-body">로그인 후 자료를 열람하고 다운로드하실 수 있습니다.</p>
          <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">로그인 ㅣ 회원가입</a>
        </div>
      </div>
    </div>
  </section>

  <!-- GUIDE -->
  <section class="section guide">
    <div class="wrap">
      <div class="guide-inner">
        <p class="eyebrow">Notice</p>
        <h2>이용 안내</h2>
        <p class="guide-body">
          자료 이용 및 회원가입 관련 문의는 카카오채널로 연락 주시기 바랍니다.<br />
          자료 이용 시 개인정보 수집 및 이용 약관에 동의하게 됩니다.
        </p>
        <div class="guide-actions">
          <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">카카오톡 상담</a>
          <a class="btn" href={withBase('/community')}>KPA 커뮤니티 바로가기</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    color: #fff;
    text-align: center;
    padding-block: clamp(80px, 14vw, 150px);
    overflow: hidden;
    background: var(--kp-maroon);
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.32;
    filter: saturate(0.9);
  }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink);
    font-size: clamp(15px, 2vw, 19px);
    margin-top: 16px;
    line-height: 1.7;
  }

  /* INTRO */
  .intro-inner { max-width: 860px; margin: 0 auto; text-align: center; }
  .intro-body { color: var(--kp-olive); font-size: clamp(15px, 1.9vw, 17px); line-height: 1.95; margin: 0 0 16px; }
  .intro-note { color: var(--kp-maroon); font-weight: 700; font-size: clamp(13px, 1.6vw, 15px); margin: 0; }

  /* CATEGORIES */
  .cats { background: var(--kp-cream); }
  .cats .eyebrow { text-align: center; }
  .cats h2 { color: var(--kp-maroon); text-align: center; font-size: clamp(26px, 4vw, 42px); margin: 6px 0 clamp(24px, 3.5vw, 40px); }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 2.5vw, 28px);
  }
  .cat-card {
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 18px;
    padding: clamp(24px, 3vw, 34px);
    box-shadow: 0 12px 30px rgba(28, 16, 18, 0.08);
  }
  .cat-card h3 { color: var(--kp-maroon); font-size: clamp(18px, 2.4vw, 22px); margin: 0 0 12px; }
  .cat-card p { color: var(--kp-olive); font-size: 15px; line-height: 1.8; margin: 0; }

  /* BOARD */
  .board-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: clamp(16px, 2.5vw, 24px);
  }
  .board-head h2 { color: var(--kp-maroon); font-size: clamp(26px, 4vw, 42px); margin: 6px 0 0; }
  .board-desc { color: var(--kp-olive); font-size: 15px; margin: 8px 0 0; }

  .board-locked { position: relative; }
  .board-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
  }
  .board-table th, .board-table td {
    text-align: left;
    padding: 16px 14px;
    border-bottom: 1px solid var(--kp-line);
  }
  .board-table thead th {
    color: var(--kp-olive);
    font-weight: 800;
    font-size: 13.5px;
    letter-spacing: 0.02em;
    border-top: 2px solid var(--kp-maroon);
    border-bottom: 1px solid var(--kp-line);
  }
  .board-table .col-title { color: var(--kp-ink); font-weight: 600; }
  .board-table .col-cat, .board-table .col-date, .board-table .col-file { white-space: nowrap; }
  .board-table .col-date { color: var(--kp-sage); }
  .tag {
    display: inline-block;
    background: var(--kp-cream);
    color: var(--kp-maroon);
    font-weight: 700;
    font-size: 12.5px;
    padding: 4px 11px;
    border-radius: 999px;
  }
  .btn--sm { padding: 8px 16px; font-size: 13px; }
  .btn[disabled] { opacity: 0.55; cursor: not-allowed; }

  /* Locked overlay */
  .board-gate {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-align: center;
    padding: 24px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0.92) 42%);
    backdrop-filter: blur(2px);
    border-radius: 8px;
  }
  .gate-lock { font-size: 40px; margin: 0; }
  .gate-title { color: var(--kp-maroon); font-weight: 800; font-size: clamp(18px, 2.6vw, 24px); margin: 0; }
  .gate-body { color: var(--kp-olive); font-size: 15px; margin: 0 0 8px; line-height: 1.7; }

  /* GUIDE */
  .guide { background: var(--kp-ink); color: #fff; text-align: center; }
  .guide-inner { max-width: 760px; margin: 0 auto; }
  .guide .eyebrow { color: var(--kp-pink); }
  .guide h2 { color: #fff; margin: 6px 0 12px; font-size: clamp(24px, 4vw, 38px); }
  .guide-body { color: var(--kp-pink); margin-bottom: 28px; line-height: 1.8; }
  .guide-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .guide .btn { border-color: var(--kp-cream); color: #fff; }
  .guide .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .guide .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .guide .btn--filled:hover { background: #fff; }

  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 620px) {
    .board-table .col-cat { display: none; }
    .board-table th.col-cat { display: none; }
  }
</style>
