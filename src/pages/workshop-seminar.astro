---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, img } from '../utils/url.js';

const kakaoChat = 'https://pf.kakao.com/_vIRDxl/chat';

// 페이지 대표 이미지
const heroImg = '6f7ec1_a83cbb7373c448a18e9b390df45c6eb1~mv2.jpeg'; // 워크샵 지도 장면
const introImg = '6f7ec1_93bbde281ca749aab671aeb92d80da7c~mv2.jpeg'; // 세미나 실습 토론
const alumniImg = '6f7ec1_bc66e70244be420aa1fb98353cc2528b~mv2.jpeg'; // 졸업생 세미나 강의
const globalImg = '6f7ec1_c9bf3003c51a461aa977cf419b8bb9a7~mv2.jpg'; // 그룹 워크샵

// 두 개의 프로그램 갈래 (졸업생 세미나 / 해외 초청 워크샵)
const tracks = [
  {
    en: 'Alumni Seminar',
    title: '졸업생 세미나',
    desc: '졸업생만을 위한 심화 실기·해부학·현장 노하우 교육으로 지도 역량을 한층 강화합니다.',
    image: alumniImg,
    href: '/graduates-seminar',
    cta: '졸업생 세미나 보기',
  },
  {
    en: 'Global Seminar',
    title: '해외 초청 워크샵',
    desc: '최신 필라테스 트렌드와 실무에 적용 가능한 고급 기술을 세계적인 마스터에게 직접 배우는 특별 프로그램입니다.',
    image: globalImg,
    href: '/conferences',
    cta: '해외 초청 워크샵 보기',
  },
];

// 졸업생 세미나 카테고리
const seminarCategories = [
  {
    en: 'Advanced anatomy seminar',
    title: '해부학 세미나',
    items: [
      '십자인대 파열 및 운동케어',
      '주요 6근육 심화스터디 (승모근, 광배근, 장요근, 복횡근, 횡격막, 골반기저근) 등',
    ],
  },
  {
    en: 'Advanced Pilates repertoire',
    title: '실기 동작 세미나',
    items: [
      '동작의 길 (교재 외 실기동작 습득)',
      '스프링보드 101 (기구소개 및 실기동작)',
      "JOSEPH'S MAGIC CIRCLE 등",
    ],
  },
  {
    en: 'Miscellaneous seminar',
    title: '그 외 세미나',
    items: [
      'NPCP 국제공인 자격취득반',
      '발레, 그리고 필라테스',
      '심폐소생술 심화과정 (CPR)',
      '산전산후 케어 솔루션 등',
    ],
  },
];

// 국내/해외 초청 워크샵 리스트
const workshops = [
  'KARFE conference : Shoulder impingement solution / Performance maximization',
  'CLT Locomotor Exercise Workshop',
  "Anthony Lett's Reformer stretch Workshop",
  'DNS Pilates Workshop by Erin Mcguire',
  'BOSU® Master class',
  'Yoga & Anatomy 등',
];

// 대표 워크샵 하이라이트
const highlights = [
  {
    tag: 'Franklin Method®',
    title: '에릭 프랭클린 워크샵',
    body: "프랭클린 메소드의 핵심이라 불리는 'Embodied Cueing Certification' 자격코스가 한국에서 개최되었습니다. 움직임을 '말'이 아닌 '경험'으로 전달하는 법, 기능적 이미지(Functional Imagery)의 구조적 적용, 레슨의 질을 바꾸는 큐잉의 원리를 깊이 있게 다룹니다.",
  },
  {
    tag: 'Exercise Course',
    title: 'CLT Exercise course 워크샵',
    body: '움직임 및 운동 관련분야 전문가과정. 협응적이고 기능적인 움직임의 기본 패턴들을 사용하여 몸의 움직임을 협응적인 형태로 연습시키는 운동 방법이자 치료법입니다.',
  },
];
---
<BaseLayout title="워크샵/세미나">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <img class="page-hero-bg" src={img(heroImg)} alt="" aria-hidden="true" />
    <div class="wrap page-hero-inner">
      <p class="eyebrow">WORKSHOP &amp; SEMINAR</p>
      <h1>워크샵 / 세미나</h1>
      <p class="page-hero-sub">
        필라테스 지도자과정 교육을 통해<br />
        필라테스의 대중화에 기여하기 위해 노력하고 있습니다.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section intro">
    <div class="wrap intro-grid">
      <div class="intro-copy">
        <p class="eyebrow">Global &amp; Alumni Pilates Seminar</p>
        <h2>지도자의 지속적인 성장을<br />위한 세미나 &amp; 워크샵</h2>
        <p class="intro-body">
          대한필라테스협회는 지도자들의 지속적인 성장을 위해 세계적 강사진 초청
          세미나와 졸업생 전용 심화 세미나를 운영합니다.
        </p>
        <ul class="intro-points">
          <li><strong>Global Seminar</strong> : 최신 필라테스 트렌드와 실무에 적용 가능한 고급 기술을 세계적인 마스터에게 직접 배우는 특별 프로그램</li>
          <li><strong>Alumni Seminar</strong> : 졸업생만을 위한 심화 실기·해부학·현장 노하우 교육으로 지도 역량을 한층 강화</li>
        </ul>
        <p class="intro-body">
          이론과 실습, 질의응답을 통해 깊이 있는 배움과 국제 네트워크를 동시에
          경험하세요. 배움의 폭을 넓히고, 필라테스 지도자로서 새로운 가능성을
          열어드립니다.
        </p>
      </div>
      <div class="intro-media">
        <img src={img(introImg)} alt="세미나 실습 및 토론 현장" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- TRACKS -->
  <section class="section tracks">
    <div class="wrap">
      <div class="track-grid">
        {tracks.map((t) => (
          <article class="track-card">
            <div class="track-media">
              <img src={img(t.image)} alt={t.title} loading="lazy" />
            </div>
            <div class="track-body">
              <p class="track-en">{t.en}</p>
              <h3>{t.title}</h3>
              <p class="track-desc">{t.desc}</p>
              <a class="btn" href={withBase(t.href)}>{t.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ALUMNI SEMINAR DETAIL -->
  <section class="section seminar">
    <div class="wrap">
      <div class="seminar-head">
        <p class="eyebrow">ALUMNI SEMINAR</p>
        <h2>졸업생 세미나</h2>
        <p class="seminar-lead">
          대한필라테스협회의 정규 지도자과정을 성공적으로 졸업하신 분들은
          ‘졸업생’이 되시며, 졸업생 세미나에 참여할 수 있는 자격이 주어집니다.
          더욱 많은 실기동작, 심층적 해부학 이론 및 실제 강사활동시에 더욱
          유용하게 사용할 수 있는 정보를 습득하여 실력을 향상시킬 수 있습니다.
        </p>
      </div>
      <div class="seminar-grid">
        {seminarCategories.map((c) => (
          <article class="seminar-card">
            <p class="seminar-en">{c.en}</p>
            <h3>{c.title}</h3>
            <ul>
              {c.items.map((i) => (
                <li>{i}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GLOBAL WORKSHOP DETAIL -->
  <section class="section global">
    <div class="wrap global-grid">
      <div class="global-copy">
        <p class="eyebrow">GLOBAL WORKSHOP</p>
        <h2>국내 / 해외 초청 워크샵</h2>
        <p class="global-lead">국내·해외에서 저명한 강사 및 교수진을 초빙한 워크샵입니다.</p>
        <p class="global-body">
          해외 초청 워크샵은 세계적인 강사진을 초빙하여 진행되는 특별
          프로그램입니다. 참가자들은 최신 트렌드와 실무에서 적용할 수 있는 고급
          기술을 직접 배울 수 있으며, 이론적 강의 뿐만 아니라 실습과 질의응답을
          통해 심층적인 이해를 돕습니다. 또한, 다양한 분야의 전문가들과 네트워크를
          형성할 수 있는 기회도 제공됩니다.
        </p>
        <ul class="workshop-list">
          {workshops.map((w) => (
            <li>{w}</li>
          ))}
        </ul>
      </div>
      <div class="global-highlights">
        {highlights.map((h) => (
          <article class="highlight-card">
            <p class="highlight-tag">{h.tag}</p>
            <h3>{h.title}</h3>
            <p>{h.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section ws-cta">
    <div class="wrap">
      <p class="eyebrow">JOIN US</p>
      <h2>워크샵 / 세미나 신청</h2>
      <p>국제적인 시각을 넓히고 역량을 강화할 수 있는 뜻깊은 시간을 함께하세요.</p>
      <div class="ws-cta-btns">
        <a class="btn btn--filled" href={withBase('/event-list')}>워크샵/세미나 신청</a>
        <a class="btn" href={kakaoChat} target="_blank" rel="noopener">카카오톡 상담</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    color: #fff;
    text-align: center;
    padding-block: clamp(80px, 14vw, 150px);
    overflow: hidden;
    background: var(--kp-maroon);
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.32;
    filter: saturate(0.9);
  }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink);
    font-size: clamp(15px, 2vw, 19px);
    margin-top: 16px;
    line-height: 1.7;
  }

  /* INTRO */
  .intro-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .intro-copy h2 { color: var(--kp-maroon); font-size: clamp(26px, 3.6vw, 40px); margin: 6px 0 20px; line-height: 1.25; }
  .intro-body { color: var(--kp-olive); font-size: clamp(14px, 1.7vw, 16px); line-height: 1.9; margin: 0 0 18px; }
  .intro-points {
    list-style: none;
    margin: 0 0 18px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .intro-points li {
    background: rgba(141, 153, 144, 0.12);
    border-left: 3px solid var(--kp-sage);
    border-radius: 0 10px 10px 0;
    padding: 14px 18px;
    color: var(--kp-ink);
    font-size: clamp(14px, 1.7vw, 16px);
    line-height: 1.75;
  }
  .intro-points strong { color: var(--kp-maroon); }
  .intro-media img {
    width: 100%;
    border-radius: 16px;
    display: block;
    box-shadow: 0 16px 38px rgba(28, 16, 18, 0.16);
  }

  /* TRACKS */
  .tracks { background: var(--kp-cream); }
  .track-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(22px, 3.5vw, 36px);
  }
  .track-card {
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 14px 34px rgba(28, 16, 18, 0.08);
    display: flex;
    flex-direction: column;
  }
  .track-media { aspect-ratio: 3 / 2; overflow: hidden; }
  .track-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .track-body { padding: clamp(22px, 3vw, 32px); display: flex; flex-direction: column; align-items: flex-start; }
  .track-en {
    font-family: var(--font-display);
    color: var(--kp-sage);
    font-weight: 800;
    letter-spacing: 0.04em;
    font-size: 14px;
    margin: 0 0 6px;
  }
  .track-body h3 { color: var(--kp-maroon); font-size: clamp(21px, 2.6vw, 27px); margin: 0 0 12px; }
  .track-desc { color: var(--kp-olive); font-size: 15px; line-height: 1.8; margin: 0 0 22px; }

  /* SEMINAR */
  .seminar-head { max-width: 820px; margin-bottom: clamp(28px, 4vw, 44px); }
  .seminar-head h2 { color: var(--kp-maroon); font-size: clamp(26px, 4vw, 42px); margin: 6px 0 18px; }
  .seminar-lead { color: var(--kp-olive); font-size: clamp(15px, 1.9vw, 17px); line-height: 1.9; margin: 0; }
  .seminar-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 30px);
  }
  .seminar-card {
    background: #fbf7ef;
    border: 1px solid var(--kp-line);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
  }
  .seminar-en {
    font-family: var(--font-display);
    color: var(--kp-sage);
    font-weight: 800;
    letter-spacing: 0.03em;
    font-size: 13px;
    margin: 0 0 4px;
  }
  .seminar-card h3 { color: var(--kp-maroon); font-size: clamp(18px, 2.2vw, 22px); margin: 0 0 16px; }
  .seminar-card ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .seminar-card li {
    position: relative;
    padding-left: 18px;
    color: var(--kp-olive);
    font-size: 14.5px;
    line-height: 1.7;
  }
  .seminar-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--kp-sage);
  }

  /* GLOBAL */
  .global { background: var(--kp-cream); }
  .global-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(28px, 5vw, 60px);
    align-items: start;
  }
  .global-copy h2 { color: var(--kp-maroon); font-size: clamp(26px, 3.6vw, 40px); margin: 6px 0 16px; }
  .global-lead { color: var(--kp-ink); font-weight: 700; font-size: clamp(16px, 1.9vw, 18px); line-height: 1.7; margin: 0 0 16px; }
  .global-body { color: var(--kp-olive); font-size: clamp(14px, 1.7vw, 16px); line-height: 1.9; margin: 0 0 22px; }
  .workshop-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .workshop-list li {
    position: relative;
    padding: 12px 16px 12px 40px;
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 10px;
    color: var(--kp-ink);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .workshop-list li::before {
    content: '✓';
    position: absolute;
    left: 15px;
    top: 12px;
    color: var(--kp-maroon);
    font-weight: 800;
  }
  .global-highlights { display: flex; flex-direction: column; gap: clamp(18px, 3vw, 24px); }
  .highlight-card {
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 16px;
    padding: clamp(22px, 3vw, 30px);
    box-shadow: 0 12px 30px rgba(28, 16, 18, 0.07);
  }
  .highlight-tag {
    font-family: var(--font-display);
    display: inline-block;
    background: var(--kp-maroon);
    color: var(--kp-cream);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 5px 12px;
    border-radius: 999px;
    margin: 0 0 12px;
  }
  .highlight-card h3 { color: var(--kp-maroon); font-size: clamp(19px, 2.4vw, 24px); margin: 0 0 12px; }
  .highlight-card p { color: var(--kp-olive); font-size: 15px; line-height: 1.85; margin: 0; }

  /* CTA */
  .ws-cta { background: var(--kp-ink); color: #fff; text-align: center; }
  .ws-cta .eyebrow { color: var(--kp-pink); }
  .ws-cta h2 { color: #fff; margin: 6px 0 12px; font-size: clamp(26px, 4vw, 40px); }
  .ws-cta p { color: var(--kp-pink); margin-bottom: 28px; line-height: 1.8; }
  .ws-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .ws-cta .btn { border-color: var(--kp-cream); color: #fff; }
  .ws-cta .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .ws-cta .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .ws-cta .btn--filled:hover { background: #fff; }

  @media (max-width: 900px) {
    .intro-grid { grid-template-columns: 1fr; }
    .intro-media { order: -1; }
    .track-grid { grid-template-columns: 1fr; }
    .seminar-grid { grid-template-columns: 1fr; }
    .global-grid { grid-template-columns: 1fr; }
  }
</style>
