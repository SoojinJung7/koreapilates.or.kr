---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase, img } from '../../utils/url.js';

const kakaoChat = 'https://pf.kakao.com/_vIRDxl/chat';

const price = '₩170,000';

// 2025 심화과정 — 정규과정 외 6개 전문 강의 (총 36시간, 오프라인)
const courses2025 = [
  { no: 1, title: '정렬 기반 체형교정 실전교육 (허리·골반·다리)', image: '6f7ec1_6d56c204104e493fb726d8b545742fd7~mv2.jpg', alt: '리포머 위에서 진행하는 정렬 기반 체형교정 실전교육' },
  { no: 2, title: '병리학 (feat. NCPT) 이론 + 실기', image: '6f7ec1_768862861dbc4078b2faad3c142dacc7~mv2.jpg', alt: '무릎 관절 엑스레이를 판독하는 병리학 이론 교육' },
  { no: 3, title: '특정 인구 (키즈·산전산후·실버) + 시퀀스', image: '6f7ec1_227dbc2d9fd24b2187ff2a101e88cde2~mv2.jpg', alt: '배럴 위에서 특수 인구군 맞춤 시퀀스를 실습하는 교육생' },
  { no: 4, title: '정규과정 외 동작 + 말단 해부학 (하지)', image: '6f7ec1_0b2243f7d9484f9a8c1adb21f3928246~mv2.jpg', alt: '하지 근육 해부 모형을 활용한 말단 해부학 교육' },
  { no: 5, title: '정렬 기반 체형교정 실전교육 (목·어깨·등)', image: '6f7ec1_396eabbbda07493ab0ab24bc02c4da26~mv2.jpg', alt: '리포머 그룹 수업으로 진행되는 상체 정렬 실전교육' },
  { no: 6, title: '정규과정 외 동작 + 말단 해부학 (상지)', image: '6f7ec1_63777a879c29431291cb523f302ee949~mv2.jpg', alt: 'KPA 아카데미 실습실에서 진행되는 동작 실기 교육' },
];
---
<BaseLayout title="심화과정 수강신청">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">ADVANCED PROGRAM</p>
      <h1>심화과정 수강신청</h1>
      <p class="page-hero-sub">
        이론과 실기를 아우르는 균형 잡힌 커리큘럼으로, 현장에서 강사로서의 전문성을 한층 높여드립니다.
        수강 시 수료증이 발급되는 교육 과정입니다.
      </p>
    </div>
  </section>

  <!-- 프로그램 소개 -->
  <section class="section intro">
    <div class="wrap">
      <p class="eyebrow">KPA ADVANCED PRACTITIONER PROGRAM</p>
      <h2>KPA 심화과정 교육</h2>
      <p class="intro-lead">
        정규과정 외 6개 전문 강의를 새롭게 편성하여, 총 <strong>36시간</strong>의 실전 중심 심화 교육을 제공합니다.
        기초 교육만으로는 부족했던 ‘실제 수업을 위한 디테일’까지 채워드립니다.
      </p>
      <p class="intro-body">
        대한필라테스협회의 심화과정은 병리학 이론·실기, 말단 해부학, 특수 인구군 맞춤 시퀀스 설계 등
        현장에서 바로 활용할 수 있는 실전 중심 교육으로 구성되어 있습니다.
        ‘가르치는 법’에 머무르지 않고, ‘전달하는 힘’을 완성합니다.
      </p>
      <p class="intro-tag">지식 전달의 기술을 배우는, 한 차원 높은 티칭 교육 <span>전체 심화과정 · 오프라인 교육 진행</span></p>
    </div>
  </section>

  <!-- 연도별 프로그램 -->
  <section class="section products">
    <div class="wrap">
      <div class="products-head">
        <div>
          <p class="eyebrow">SCHEDULE</p>
          <h2>연도별 프로그램</h2>
        </div>
        <div class="tabs" role="tablist" aria-label="연도별 심화과정">
          <button class="tab is-active" role="tab" aria-selected="true" data-tab="y2025">2025 심화과정</button>
          <button class="tab" role="tab" aria-selected="false" data-tab="y2026">2026 심화과정</button>
        </div>
      </div>

      <!-- 2025 -->
      <div class="tab-panel is-active" id="y2025" role="tabpanel">
        <div class="product-grid">
          {courses2025.map((c) => (
            <article class="product">
              <div class="product-media">
                <img src={img(c.image)} alt={c.alt} loading="lazy" />
                <span class="product-no">{c.no}</span>
                <span class="product-flag">교육 완료</span>
              </div>
              <div class="product-body">
                <h3>{c.title}</h3>
                <p class="product-meta">오프라인 교육 · 수료증 발급</p>
                <div class="product-foot">
                  <span class="product-price">{price}</span>
                  <span class="btn btn--sm btn--disabled" aria-disabled="true">마감</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- 2026 -->
      <div class="tab-panel" id="y2026" role="tabpanel" hidden>
        <div class="soon">
          <p class="soon-eyebrow">COMING SOON</p>
          <h3>2026 심화과정 프로그램을 준비 중입니다</h3>
          <p>
            2026년 심화과정 커리큘럼과 일정은 곧 공개될 예정입니다.
            자세한 개강 안내는 전화 상담 혹은 카카오톡으로 문의해 주세요.
          </p>
          <div class="soon-btns">
            <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">카카오톡 문의</a>
            <a class="btn" href="tel:0317287724">031-728-7724</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 신청 안내 -->
  <section class="section apply-notice">
    <div class="wrap">
      <div class="notice-grid">
        <div class="notice-card">
          <h3>수강 안내</h3>
          <ul>
            <li>전체 심화과정은 오프라인으로 진행되며, 각 과정 수강 시 수료증이 발급됩니다.</li>
            <li>수강료는 과정별 <strong>{price}</strong> (현금 / 카드 동일)입니다.</li>
            <li>정원이 한정되어 있어 조기 마감될 수 있습니다.</li>
            <li>개강 일정 및 신청은 전화 혹은 방문 상담을 통해 안내드립니다. (문의처 : 031-728-7724)</li>
          </ul>
        </div>
        <div class="notice-card notice-card--terms">
          <h3>개인정보 수집 및 이용 약관</h3>
          <p>
            수강신청 시 성명·연락처 등 개인정보를 수집하며, 수집한 정보는 교육 신청·운영 및 안내 목적으로만
            이용됩니다. 수집한 개인정보는 관계 법령에 따라 안전하게 관리되며, 이용 목적이 달성된 후에는
            지체 없이 파기합니다.
          </p>
          <label class="terms-agree">
            <input type="checkbox" disabled />
            <span>개인정보 수집 및 이용에 동의합니다.</span>
          </label>
          <p class="terms-hint">※ 온라인 신청 기능은 준비 중입니다. 현재는 전화·방문 상담으로 접수합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section course-cta">
    <div class="wrap">
      <h2>심화과정으로 전문성을 완성하세요</h2>
      <p>개강 일정을 확인하고, 궁금한 점은 카카오톡 혹은 전화로 상담하세요.</p>
      <div class="course-cta-btns">
        <a class="btn btn--filled" href={kakaoChat} target="_blank" rel="noopener">카카오톡 상담</a>
        <a class="btn" href={withBase('/curriculum')}>커리큘럼 보기</a>
        <a class="btn" href={withBase('/coursedate')}>교육일정 보기</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.tab-panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        const active = p.id === target;
        p.classList.toggle('is-active', active);
        p.hidden = !active;
      });
    });
  });
</script>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--kp-maroon);
    color: #fff;
    text-align: center;
    padding-block: clamp(70px, 12vw, 130px);
  }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink);
    font-size: clamp(15px, 2vw, 19px);
    margin-top: 16px;
    max-width: 760px;
    margin-inline: auto;
    line-height: 1.8;
  }

  /* INTRO */
  .intro { text-align: center; }
  .intro h2 { color: var(--kp-maroon); font-size: clamp(26px, 4vw, 40px); margin: 6px 0 22px; }
  .intro-lead {
    color: var(--kp-ink);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.85;
    max-width: 780px;
    margin: 0 auto 18px;
  }
  .intro-lead strong { color: var(--kp-maroon); }
  .intro-body {
    color: var(--kp-olive);
    font-size: clamp(15px, 1.8vw, 17px);
    line-height: 1.9;
    max-width: 780px;
    margin: 0 auto 26px;
  }
  .intro-tag {
    display: inline-block;
    background: var(--kp-cream);
    color: var(--kp-maroon);
    font-weight: 700;
    font-size: clamp(14px, 1.7vw, 16px);
    padding: 14px 26px;
    border-radius: 999px;
  }
  .intro-tag span {
    display: block;
    color: var(--kp-olive);
    font-weight: 500;
    font-size: 13px;
    margin-top: 4px;
  }

  /* PRODUCTS */
  .products { background: var(--kp-cream); }
  .products-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: clamp(24px, 4vw, 40px);
  }
  .products-head h2 { color: var(--kp-maroon); font-size: clamp(24px, 3.4vw, 34px); margin: 6px 0 0; }
  .tabs {
    display: inline-flex;
    background: #fff;
    border-radius: 999px;
    padding: 5px;
    gap: 4px;
  }
  .tab {
    border: 0;
    background: transparent;
    color: var(--kp-olive);
    font-family: inherit;
    font-size: 14px;
    font-weight: 700;
    padding: 10px 20px;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
  }
  .tab.is-active { background: var(--kp-maroon); color: #fff; }

  .tab-panel { display: none; }
  .tab-panel.is-active { display: block; }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 3vw, 28px);
  }
  .product {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 18px rgba(59, 30, 34, 0.06);
  }
  .product-media { position: relative; }
  .product-media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    filter: grayscale(0.15);
  }
  .product-no {
    position: absolute;
    top: 12px;
    left: 12px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--kp-maroon);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .product-flag {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(28, 16, 18, 0.72);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 999px;
  }
  .product-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .product-body h3 {
    color: var(--kp-ink);
    font-size: clamp(16px, 1.9vw, 18px);
    line-height: 1.5;
    margin: 0 0 8px;
  }
  .product-meta { color: var(--kp-sage); font-size: 13px; margin: 0 0 18px; }
  .product-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .product-price {
    font-family: var(--font-display);
    color: var(--kp-maroon);
    font-weight: 800;
    font-size: clamp(18px, 2.2vw, 21px);
  }
  .btn--sm { padding: 8px 18px; font-size: 13px; }
  .btn--disabled {
    color: var(--kp-sage);
    border-color: var(--kp-line);
    background: transparent;
    cursor: default;
    pointer-events: none;
  }

  /* COMING SOON */
  .soon {
    background: #fff;
    border-radius: 12px;
    padding: clamp(40px, 7vw, 80px) clamp(24px, 4vw, 48px);
    text-align: center;
  }
  .soon-eyebrow {
    color: var(--kp-sage);
    font-weight: 800;
    letter-spacing: 0.14em;
    font-size: 13px;
    margin: 0 0 12px;
  }
  .soon h3 { color: var(--kp-maroon); font-size: clamp(20px, 3vw, 28px); margin: 0 0 14px; }
  .soon p {
    color: var(--kp-olive);
    font-size: 15px;
    line-height: 1.8;
    max-width: 560px;
    margin: 0 auto 26px;
  }
  .soon-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* APPLY NOTICE */
  .notice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(18px, 3vw, 28px);
  }
  .notice-card {
    background: #fbf7ef;
    border-radius: 12px;
    padding: clamp(24px, 3vw, 34px);
  }
  .notice-card h3 { color: var(--kp-maroon); font-size: clamp(18px, 2.2vw, 21px); margin: 0 0 16px; }
  .notice-card ul { list-style: none; margin: 0; padding: 0; }
  .notice-card li {
    color: var(--kp-olive);
    font-size: 15px;
    line-height: 1.75;
    padding-left: 18px;
    position: relative;
    margin-bottom: 10px;
  }
  .notice-card li:last-child { margin-bottom: 0; }
  .notice-card li::before { content: '·'; position: absolute; left: 5px; color: var(--kp-sage); font-weight: 700; }
  .notice-card li strong { color: var(--kp-maroon); }
  .notice-card--terms p { color: var(--kp-olive); font-size: 15px; line-height: 1.8; margin: 0 0 16px; }
  .terms-agree {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--kp-ink);
    font-size: 14px;
    font-weight: 600;
    background: #fff;
    border: 1px solid var(--kp-line);
    border-radius: 8px;
    padding: 12px 16px;
  }
  .terms-agree input { width: 16px; height: 16px; accent-color: var(--kp-maroon); }
  .terms-hint { color: var(--kp-sage) !important; font-size: 13px !important; margin: 14px 0 0 !important; }

  /* CTA */
  .course-cta { background: var(--kp-ink); color: #fff; text-align: center; }
  .course-cta h2 { color: #fff; margin-bottom: 12px; }
  .course-cta p { color: var(--kp-pink); margin-bottom: 28px; }
  .course-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .course-cta .btn { border-color: var(--kp-cream); color: #fff; }
  .course-cta .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .course-cta .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .course-cta .btn--filled:hover { background: #fff; }

  @media (max-width: 900px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
    .notice-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .product-grid { grid-template-columns: 1fr; max-width: 400px; margin-inline: auto; }
    .products-head { flex-direction: column; align-items: stretch; }
  }
</style>
