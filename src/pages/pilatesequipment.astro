---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, img } from '../utils/url.js';

// 필라테스 기구 — 원본 순서 그대로 (조셉 필라테스로부터 시작된 기구 소개)
const equipment = [
  {
    name: '캐딜락',
    en: 'Cadillac',
    desc: '조셉 필라테스(Joseph Pilates)가 만든 최초 필라테스 기구. 침대 형태로 된 기구이다. 스프링 및 여러가지 도구들이 장착되어 있어 동작들을 보조해주거나 변형동작 응용이 가능하다. 표면적이 넓어 안정성이 가장 높다.',
    image: '6f7ec1_b58e42c0ba5f4042889050bf0381d1a0~mv2.jpg',
    alt: '침대 형태의 필라테스 기구 캐딜락',
  },
  {
    name: '리포머',
    en: 'Reformer',
    desc: '유일하게 캐리지가 움직이는 기구이다. 스프링이 가로로 달려있어서 동작에 따라 좌우 움직임이 가능하다. 엎드린 자세, 서 있는 자세, 네발기기 자세 등 다양한 동작을 응용할 수 있고 캐리지 자체가 움직이기 때문에 코어의 안정성, 균형감각과 근력, 고유수용감각을 발달시키는데 도움이 된다.',
    image: '6f7ec1_bf3e15db83b94b78ade5e66c0037ccdc~mv2.jpg',
    alt: '캐리지가 움직이는 필라테스 기구 리포머',
  },
  {
    name: '배럴',
    en: 'Ladder Barrel',
    desc: '척추의 커브에 가장 근접하게 만들어진 기구이다. 이 기구의 동그랗게 생긴 부분 자체를 배럴이라고 한다. 이 부분에 척추의 모든 부위를 기댈 수 있게끔 되어있어 상대적으로 다른 기구보다 척추의 유연성을 높여주고 허리를 효과적으로 쉴 수 있게 한다. 엎드려서 하는 동작이 많다.',
    image: '6f7ec1_570078d1c9cd44b18a8a227c39cd0992~mv2.jpg',
    alt: '척추 커브에 맞춘 필라테스 기구 배럴',
  },
  {
    name: '체어',
    en: 'Chair',
    desc: '필라테스 기구 중 표면적이 가장 적은 기구이다. 그래서 동작을 할 때 자세가 불안정해지고 그만큼 높은 근력이 요구된다. 동작을 보조할 수 있도록 페달과 스프링이 달려있다. 앉은 상태의 동작에서라든지 런지와 같은 동작에서 다른 기구들보다 기능적인 부분에서 체간의 안정성을 길러준다. 또한 체어에서의 동작을 통해 견갑골의 움직임을 더 자세히 볼 수 있다.',
    image: '6f7ec1_8a85f11e8ac647f2b0071ce444d2a5c2~mv2.jpg',
    alt: '페달과 스프링이 달린 필라테스 기구 체어',
  },
  {
    name: '매트',
    en: 'Mat',
    desc: '가장 기본적인 필라테스 자세 및 동작을 할 때 사용한다. 자신의 체중을 저항으로 이용하기 때문에 기초체력을 기르기에 좋다. 다른 기구보다 안전사고 위험성이 가장 낮으며 들고 다니기가 편해서 어디서나 운동할 수 있는 점이 있다.',
    image: '6f7ec1_3a75f1cede5b4169894a815285ff0049~mv2.jpg',
    alt: '기본 필라테스 동작에 사용하는 매트',
  },
  {
    name: '소도구',
    en: 'Small Apparatus',
    desc: '필라테스 기구들은 테일러 메이드(맞춤형 제작)이 아니기 때문에 디테일한 운동 보조 능력이 다소 약하다. 하지만 소도구를 활용하면 사람의 체형에 맞추어 더욱 세밀한 난이도 조절 및 운동 보조가 가능하다. 소도구에는 오버볼, 서클, 밴드, 보수, 폼롤러, 짐볼 등과 같은 도구들이 있다.',
    image: '6f7ec1_b2cb164c90b942ebb7413edadaf2846a~mv2.jpg',
    alt: '오버볼, 서클, 밴드 등 필라테스 소도구',
  },
  {
    name: '스프링보드',
    en: 'Spring Board',
    note: '교과과정 외',
    desc: '캐딜락의 부피로 인해 효율적인 공간사용이 어려운 경우 사용한다. 캐딜락의 타워 엔드(Tower-end), 그리고 오픈 엔드(Open-end)에 설치된 PT바 / 롤다운 바 / 암스프링 / 풋스프링이 모두 한 판에 붙여진 형식이며, 매달리기 동작을 제외한 대부분의 캐딜락 동작이 가능하다.',
    image: '6f7ec1_d8369b921891431e983f082df7488d30~mv2.jpg',
    alt: '벽면에 설치하는 필라테스 기구 스프링보드',
  },
];
---
<BaseLayout title="장비 둘러보기">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">EQUIPMENT</p>
      <h1>장비 둘러보기</h1>
      <p class="page-hero-sub">필라테스 창시자 조셉 필라테스로부터 시작된 다양한 기구들</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section intro">
    <div class="wrap intro-wrap">
      <p class="lead">
        필라테스 창시자 조셉 필라테스(Joseph Pilates)로부터 시작된<br />
        다양한 필라테스 기구들을 소개합니다.
      </p>
      <p>
        국내 최대 시설을 통해 회원들에게 쾌적한 교육환경 및 훈련공간을 제공합니다.
      </p>
    </div>
  </section>

  <!-- EQUIPMENT -->
  <section class="section equip">
    <div class="wrap">
      <div class="equip-list">
        {equipment.map((e, i) => (
          <article class={`equip-item ${i % 2 === 1 ? 'equip-item--reverse' : ''}`}>
            <div class="equip-media">
              <img src={img(e.image)} alt={e.alt} loading="lazy" />
            </div>
            <div class="equip-body">
              <p class="equip-en">{e.en}</p>
              <h2>
                {e.name}
                {e.note && <span class="equip-note">{e.note}</span>}
              </h2>
              <p class="equip-desc">{e.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section equip-cta">
    <div class="wrap">
      <h2>기구를 직접 만져보고 경험해 보세요</h2>
      <div class="equip-cta-btns">
        <a class="btn btn--filled" href={withBase('/projects')}>시설 둘러보기</a>
        <a class="btn" href={withBase('/address')}>오시는길</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--kp-maroon);
    color: #fff;
    text-align: center;
    padding-block: clamp(70px, 12vw, 130px);
  }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub { color: var(--kp-pink); font-size: clamp(16px, 2vw, 20px); margin-top: 14px; }

  /* INTRO */
  .intro { text-align: center; }
  .intro-wrap { max-width: 820px; }
  .intro .lead {
    font-size: clamp(21px, 2.8vw, 30px);
    color: var(--kp-maroon);
    font-weight: 700;
    line-height: 1.45;
    margin-bottom: 18px;
  }
  .intro p { color: var(--kp-olive); }

  /* EQUIPMENT */
  .equip { padding-top: 0; }
  .equip-list { display: grid; gap: clamp(40px, 7vw, 90px); }
  .equip-item {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .equip-item--reverse .equip-media { order: 2; }
  .equip-media {
    overflow: hidden;
    border-radius: 6px;
    box-shadow: 0 18px 40px rgba(28, 16, 18, 0.12);
  }
  .equip-media img {
    display: block; width: 100%; height: 100%;
    aspect-ratio: 3 / 2; object-fit: cover;
    transition: transform .6s ease;
  }
  .equip-item:hover .equip-media img { transform: scale(1.04); }
  .equip-en {
    font-family: var(--font-display);
    letter-spacing: 0.18em;
    color: var(--kp-sage);
    font-size: 14px;
    margin: 0 0 10px;
  }
  .equip-body h2 { color: var(--kp-maroon); margin: 0 0 18px; display: flex; align-items: baseline; flex-wrap: wrap; gap: 10px; }
  .equip-note {
    font-size: 13px; font-weight: 500;
    color: var(--kp-sage);
    border: 1px solid var(--kp-sage);
    border-radius: 999px;
    padding: 3px 11px;
  }
  .equip-desc { color: var(--kp-olive); font-size: clamp(15px, 1.8vw, 17px); line-height: 1.75; margin: 0; }

  /* CTA */
  .equip-cta { background: var(--kp-ink); color: #fff; text-align: center; }
  .equip-cta h2 { color: #fff; margin-bottom: 30px; }
  .equip-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .equip-cta .btn { border-color: var(--kp-cream); color: #fff; }
  .equip-cta .btn:hover { background: var(--kp-cream); color: var(--kp-ink); }
  .equip-cta .btn--filled { background: var(--kp-cream); color: var(--kp-ink); border-color: var(--kp-cream); }
  .equip-cta .btn--filled:hover { background: #fff; }

  @media (max-width: 760px) {
    .equip-item { grid-template-columns: 1fr; }
    .equip-item--reverse .equip-media { order: 0; }
  }
</style>
