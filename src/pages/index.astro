---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, img } from '../utils/url.js';

const hero = '6f7ec1_f36aeed6d4d946d2b906ca35afd19f27~mv2.jpg';

const features = [
  { t: '6인 소수정예 꽉 찬 250시간', d: '한 반 최대 6인. 밀도 높은 250시간 정규 커리큘럼.' },
  { t: '커뮤니티 기반 학습 지원', d: '실시간 질의응답과 지식 공유로 함께 성장합니다.' },
  { t: '과제 제출 및 피드백', d: '제출한 과제에 강사가 1:1 맞춤 피드백을 드립니다.' },
  { t: '심화과정 36시간 세미나/워크샵', d: '정규 외 심화 세미나·워크샵으로 전문성을 더합니다.' },
  { t: '이력서·자기소개서 작성 & 취업 지원', d: '이력서/자소서부터 면접 준비까지 취업을 돕습니다.' },
  { t: '드레스업 데이', d: '전문가 이미지 메이킹 워크샵, 드레스업 데이.' },
  { t: '교육생 시설 이용 혜택', d: '필라테스 스튜디오·헬스·GX·스파를 무료로 이용.' },
];

const courses = [
  { n: '1', t: '정렬 기반 체형교정 실전교육 (허리·골반·다리)' },
  { n: '2', t: '병리학 (feat. NCPT) 이론 + 실기' },
  { n: '3', t: '특정 인구(키즈·산전산후·실버) + 시퀀스' },
  { n: '4', t: '교재 외 동작 + 말단 해부학 (하지)' },
  { n: '5', t: '정렬 기반 체형교정 실전교육 (목·어깨·등)' },
  { n: '6', t: '정규과정 외 동작 + 말단 해부학 (상지)' },
];

const workshops = [
  { t: 'Franklin Method® 에릭 프랭클린 워크샵', img: '6f7ec1_9f6015ebafd14b97b64037b4e1702540~mv2.jpg' },
  { t: 'Exercise Course 워크샵', img: '6f7ec1_63d891a3e69148d6aca9880cfd26d66a~mv2.jpg' },
  { t: "필라테스 전문 세미나 'Innovations in Pilates'", img: '6f7ec1_358557b5f0614388ba997cca26bc516a~mv2.jpg' },
  { t: '보수(BOSU)와 필라테스의 만남', img: '6f7ec1_07ef8e2dee444480824bd48bbfebe95e~mv2.jpg' },
];

const partners = [
  { tag: '토탈 휘트니스 클럽', name: '스포츠클럽 필립', desc: '몸과 마음을 바로 세우는 곳. 필립(必立)은 건강한 몸에서부터 건전한 마음을 만드는 쾌적한 공간입니다.' },
  { tag: '성장기 운동은 교육입니다', name: '발리 유소년 스포츠클럽', desc: '성장기 아이들을 위한 체계적인 유소년 스포츠 교육.' },
  { tag: '자이로토닉 국제인증강사 교육기관', name: '더 스파이럴 분당', desc: 'Gyrotonic® 국제인증강사 과정을 운영하는 교육기관.' },
  { tag: '1:1 / 듀엣 / 3:1 기구필라테스', name: '필라인필립 스튜디오', desc: '개인 맞춤형 기구 필라테스 프라이빗 스튜디오.' },
];
---
<BaseLayout>
  <!-- HERO -->
  <section class="hero" style={`background-image:linear-gradient(rgba(28,16,18,.42),rgba(28,16,18,.42)),url(${img(hero)})`}>
    <div class="wrap hero-inner">
      <p class="hero-en">The first Pilates Educating Corporation in Korea</p>
      <h1>국내최초 사단법인<br />필라테스 교육기관</h1>
      <a class="btn btn--filled hero-cta" href={withBase('/coursedate')}>지도자과정 교육일정</a>
    </div>
  </section>

  <!-- 메인 메시지 -->
  <section class="section message">
    <div class="wrap">
      <p class="eyebrow">KPA EDUCATION SYSTEM</p>
      <h2>실무에 강하다!</h2>
      <p class="message-sub">필라테스 전문가를 양성하는<br />KPA의 체계적 교육 시스템</p>
    </div>
  </section>

  <!-- 특징 -->
  <section class="section features">
    <div class="wrap">
      <div class="feature-grid">
        {features.map((f, i) => (
          <article class="feature-card">
            <span class="feature-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{f.t}</h3>
            <p>{f.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Journey -->
  <section class="section journey" style={`background-image:linear-gradient(rgba(28,16,18,.5),rgba(28,16,18,.5)),url(${img('6f7ec1_768862861dbc4078b2faad3c142dacc7~mv2.jpg')})`}>
    <div class="wrap">
      <h2 class="journey-title">Journey with KPA</h2>
    </div>
  </section>

  <!-- 심화과정 -->
  <section class="section advanced">
    <div class="wrap">
      <p class="eyebrow">ADVANCED COURSE</p>
      <h2>지식 전달의 기술을 배우는,<br />KPA 심화과정</h2>
      <p class="advanced-target">교육대상 · 사단법인 대한필라테스협회 졸업생 및 타 협회 필라테스 강사</p>
      <div class="course-grid">
        {courses.map((c) => (
          <article class="course-card">
            <span class="course-num">{c.n}</span>
            <p>{c.t}</p>
          </article>
        ))}
      </div>
      <a class="btn advanced-cta" href={withBase('/category/all-products')}>심화과정 수강신청</a>
    </div>
  </section>

  <!-- 후기 -->
  <section class="section testimonial">
    <div class="wrap">
      <blockquote>
        “이력서 작성하는 게 걱정되었는데, 강사님께서 꼼꼼하게 내용 피드백 해주셔서 쉽게 해결되었습니다!
        너무 너무 만족한 6개월 수강이었어요.”
      </blockquote>
      <cite>— 155기 졸업생 박○○ —</cite>
    </div>
  </section>

  <!-- 워크샵 -->
  <section class="section workshops">
    <div class="wrap">
      <p class="eyebrow">WORKSHOP &amp; SEMINAR</p>
      <h2>워크샵 · 세미나</h2>
      <div class="workshop-grid">
        {workshops.map((w) => (
          <a class="workshop-card" href={withBase('/workshop-seminar')}>
            <div class="workshop-img" style={`background-image:url(${img(w.img)})`}></div>
            <h3>{w.t}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Brand -->
  <section class="section brand">
    <div class="wrap">
      <p class="eyebrow">OUR BRAND</p>
      <h2>함께하는 브랜드</h2>
      <div class="partner-grid">
        {partners.map((p) => (
          <article class="partner-card">
            <p class="partner-tag">{p.tag}</p>
            <h3>{p.name}</h3>
            <p class="partner-desc">{p.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    background-size: cover; background-position: center;
    color: #fff; min-height: 82vh; display: flex; align-items: center;
  }
  .hero-inner { text-align: center; width: 100%; }
  .hero-en { letter-spacing: 0.22em; font-size: 14px; text-transform: uppercase; color: var(--kp-cream); margin-bottom: 18px; }
  .hero h1 { font-size: clamp(34px, 6vw, 68px); color: #fff; line-height: 1.18; margin-bottom: 34px; }
  .hero-cta { border-color: var(--kp-cream); }

  /* MESSAGE */
  .message { text-align: center; }
  .message h2 { font-size: clamp(30px, 5vw, 52px); color: var(--kp-maroon); }
  .message-sub { font-size: clamp(17px, 2vw, 21px); color: var(--kp-olive); margin-top: 8px; }

  /* FEATURES */
  .feature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 2px; background: var(--kp-line); border: 1px solid var(--kp-line); }
  .feature-card { background: #fff; padding: 40px 30px; transition: background .3s; }
  .feature-card:hover { background: var(--kp-cream); }
  .feature-num { font-family: var(--font-display); font-size: 28px; color: var(--kp-sage); }
  .feature-card h3 { font-size: 19px; margin: 14px 0 10px; color: var(--kp-ink); font-family: var(--font-sans); font-weight: 600; letter-spacing: 0; }
  .feature-card p { font-size: 14px; color: var(--kp-olive); margin: 0; }

  /* JOURNEY */
  .journey { background-size: cover; background-position: center; text-align: center; }
  .journey-title { font-size: clamp(36px, 6vw, 72px); color: #fff; letter-spacing: 0.06em; }

  /* ADVANCED */
  .advanced { text-align: center; background: var(--kp-cream); }
  .advanced h2 { color: var(--kp-maroon); font-size: clamp(28px, 4.5vw, 46px); }
  .advanced-target { color: var(--kp-olive); font-size: 15px; margin-bottom: 40px; }
  .course-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; text-align: left; }
  .course-card { background: #fff; padding: 26px 24px; display: flex; gap: 18px; align-items: flex-start; }
  .course-num { font-family: var(--font-display); font-size: 30px; color: var(--kp-sage); line-height: 1; }
  .course-card p { margin: 4px 0 0; font-size: 16px; color: var(--kp-ink); }
  .advanced-cta { margin-top: 40px; }

  /* TESTIMONIAL */
  .testimonial { text-align: center; background: var(--kp-olive); color: #fff; }
  .testimonial blockquote { font-family: var(--font-display); font-size: clamp(19px, 2.6vw, 27px); line-height: 1.6; max-width: 820px; margin: 0 auto 20px; font-style: italic; }
  .testimonial cite { font-style: normal; color: var(--kp-cream); letter-spacing: 0.1em; font-size: 14px; }

  /* WORKSHOPS */
  .workshops h2 { color: var(--kp-maroon); margin-bottom: 40px; }
  .workshop-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; }
  .workshop-card { display: block; }
  .workshop-img { aspect-ratio: 4 / 3; background-size: cover; background-position: center; margin-bottom: 16px; transition: transform .4s; }
  .workshop-card:hover .workshop-img { transform: scale(1.03); }
  .workshop-card h3 { font-size: 16px; font-family: var(--font-sans); font-weight: 600; letter-spacing: 0; color: var(--kp-ink); }

  /* BRAND */
  .brand { background: var(--kp-ink); color: #fff; }
  .brand h2 { color: #fff; margin-bottom: 40px; }
  .brand .eyebrow { color: var(--kp-sage); }
  .partner-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 28px; }
  .partner-card { border: 1px solid rgba(255,255,255,0.14); padding: 34px 28px; transition: border-color .3s; }
  .partner-card:hover { border-color: var(--kp-cream); }
  .partner-tag { font-size: 12px; letter-spacing: 0.1em; color: var(--kp-sage); margin: 0 0 10px; }
  .partner-card h3 { color: var(--kp-cream); font-size: 22px; margin: 0 0 14px; }
  .partner-desc { font-size: 14px; color: rgba(255,255,255,0.72); margin: 0; }
</style>
