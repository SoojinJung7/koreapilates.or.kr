---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, img } from '../utils/url.js';

const kakaoChat = 'https://pf.kakao.com/_vIRDxl/chat';

// 협회만의 차별화 교육 (원본 순서 그대로)
const features = [
  {
    no: '01',
    title: '필라테스 로직기반 커리큘럼',
    body: '필수적으로 알아야 할 기초·기능해부학, 필라테스 이론, 매트동작, 대기구별 실기동작 및 기구간 연계성을 함께 다루며, 체형분석, 프로그램(시퀀스 설계) 및 개인별 고유의 신체능력을 고려한 소도구 및 변형동작(modification)을 통해 난이도 조절방법을 가르쳐 필라테스 로직과 정확한 동작 퍼포먼스를 형성합니다. 교육종료 직후 실제 강사활동이 원활하도록 교육합니다.',
  },
  {
    no: '02',
    title: '충분한 교육기간과 거품을 뺀 교육비',
    body: '최대정원 6명 소수정예로 반년간의 충분한 시간을 들여 실력이 탄탄한 필라테스 강사를 양성합니다. 뿐만 아니라 교육과정 중에는 언제든 원하는 시간에 와서 연습할 수 있도록 스튜디오를 오픈합니다.',
    hours: {
      title: 'KPA 지도자과정 250시간',
      items: [
        '사전레슨 4시간 (멘토레슨)',
        '교육 105시간',
        '기타교육 5시간 (드레스업, 프로필사진)',
        '개인실습 20시간 / 수련·스터디·티칭 80시간',
        '심화교육 36시간 (월 1회 6시간, 총 6회)',
      ],
    },
  },
  {
    no: '03',
    title: '현장(실전) 중심 트레이닝',
    body: '가장 중요하고 활용도가 높은 운동법 및 스포츠재활 지식을 더한 집중 과정을 통해 완벽하게 이해하여 다양한 회원 상황에 따라 변화를 적용할 수 있는 능력을 기릅니다.',
  },
  {
    no: '04',
    title: '정규과정 외 재교육',
    body: '필라테스 컨퍼런스의 Case Study를 통한 티칭 능력을 향상 시킵니다. 현 교육생 및 졸업생, 현재 필라테스 강사 모두 참여 가능합니다.',
  },
  {
    no: '05',
    title: '이력서 & 동작프로필',
    body: "필라테스 강사로 발돋움하기 위한 첫 관문은 '이력서'입니다. 지도자과정 내에서 함께 이력서를 만들며, 자기소개서 및 이력서를 꼼꼼하게 첨삭해 드립니다. 필라테스 프로필 촬영의 막막함을 알기에, 동작 프로필을 내부적으로 진행하여 신입 강사 채용 성공률을 높였습니다. 필라테스 강사활동의 첫 시작, 눈길이 한 번 더 가는 이력서와 함께 보람찬 강사생활을 시작하세요.",
  },
  {
    no: '06',
    title: '면접 Q&A',
    body: '이력서를 보낸 다음엔 면접이 기다리고 있습니다. 스튜디오가 필요로 하는 인재상에 맞춘 교육을 진행하며, 면접시 주로 나오는 질문들을 미리 대비하여 자신있는 인터뷰를 진행합니다. 면접은 일방적인 것이 아닌 서로 알아가는 과정임을 기억하며, 강사로 활동하기 전 알아야 할 TIP과 정보를 아낌없이 나눠드립니다.',
  },
  {
    no: '07',
    title: '스포츠클럽필립 정직원 면접연계',
    body: "사단법인 대한필라테스협회장님의 '스포츠클럽 필립'은 2002년부터 현재까지 안정적으로 성장하는, 탄탄한 토탈휘트니스클럽입니다. 현재 활동중인 필라테스 강사는 모두 본 협회 출신이며, 운동과학센터(SFM), Personal Training, 골프, 수영장, 사우나 등의 시설을 몸소 체험하여 '건강'에 대한 시야를 넓힐 수 있습니다.",
    image: '6f7ec1_96aeb34a6b624f919b24d05d63deb858~mv2.jpg',
    imageAlt: '스포츠클럽 필립 건물 전경',
  },
];

// 교육 현장 사진 밴드
const gallery = [
  { src: '6f7ec1_523e53a745f44897bf4460f2410ff12b~mv2.jpg', alt: '기초해부학 · 필라테스 이론 강의' },
  { src: '6f7ec1_24017a8ff1fd4b64a5ce218d84cbac76~mv2.jpg', alt: '배럴 실기 트레이닝' },
  { src: '6f7ec1_64fec51b969e470896c66d3e9727b097~mv2.jpg', alt: '캐딜락 핸즈온 지도' },
  { src: '6f7ec1_da8be85ddac2492c908a640c66869f5f~mv2.jpg', alt: '기구 동작 정렬 지도' },
  { src: '6f7ec1_9fabf62948204f29b8c22a4e672e15e2~mv2.jpg', alt: '동작 프로필 촬영' },
  { src: '6f7ec1_bdb5f42bac934d1c8b003a050ec0be54~mv2.jpg', alt: '이력서 · 면접 첨삭 상담' },
];

// 지도자과정 커리큘럼 (과목 · 교육내용)
const curriculum = [
  {
    subjects: ['사전 레슨'],
    intro: '정규 지도자과정 수강 전, 기초 개념과 동작을 미리 익혀 수업 적응력을 높이는 준비 과정입니다.',
    lines: [
      '정규 과정 시작 전, 본인의 체형 / 정렬 / 가동범위 파악',
      '기본적인 필라테스 호흡법 / 주요 관절별 움직임 학습',
      '기본적인 기구별 안전수칙 습득 및 동작 체험',
    ],
  },
  {
    subjects: ['기초해부학', '필라테스 이론'],
    lines: [
      '인체 주요 골격과 근육의 구조, 기능, 크기, 위치 이해',
      '근골격계의 상호 관계 및 움직임의 기본 원리 파악',
      '관절의 종류와 운동 범위, 움직임의 면(평면)과 축(axis) 개념 정리',
      '기초 신체운동학(키네시올로지) 이론 소개 및 적용 방법',
      '필라테스 창시자 조셉 필라테스의 생애와 운동 철학',
      '필라테스의 6대 원칙(호흡, 집중, 중심화, 조절, 정확성, 흐름)의 이해',
      '단계별 필라테스 호흡법 티칭 / 큐잉법(Cueing) 개론',
    ],
  },
  {
    subjects: ['필라테스 자세측정', '필라테스 프로그램 (시퀀스)'],
    lines: [
      '필라테스 체형별 분석 및 자세측정에 대한 기준, 필라테스 테마 설정법 습득',
      '첫 레슨시 진행되는 인터뷰 › 체형분석 › 동작 › 상담시 진행되는 세부 내용 및 에티켓 교육',
      '자세측정 정보를 토대로 필라테스 프로그램 설계 및 실습',
      '난이도별 동작 정렬방법 교육 및 지속적인 개별적 프로그램 작성 연습',
    ],
  },
  {
    subjects: ['매트', '리포머'],
    lines: [
      '모든 필라테스 동작의 기본을 배우는 과정',
      '기구동작 습득 전 정확한 자세 정렬법 습득',
      '대표 동작 시범 및 정확한 동작 메커니즘 분석',
      '리포머를 이용한 필라테스 동작 습득 및 세부 세팅법 / 핸즈온 습득',
      '1:1 / 그룹레슨의 특징과 차이점에 맞는 티칭법 전수',
      '정렬(Alignment) 및 안정성 확보를 위한 큐잉 전략',
      '주의사항 및 상황별 대처 전략 습득',
    ],
  },
  {
    subjects: ['캐딜락', '체어', '배럴'],
    lines: [
      '기구별 구조 이해 및 안전 교육',
      '기구별 주요 동작 습득 및 실습',
      '지도자 중심의 핸즈온(Hands-on) 지도법 트레이닝',
    ],
  },
  {
    subjects: ['소도구'],
    lines: [
      '짐볼, 보수, 폼롤러, 서클, 밴드, 스파인코렉터를 활용한 응용동작 습득',
      '체형에 따른 소도구별 기능 및 적용법',
      '시각적, 촉각적, 언어적 큐잉의 통합 활용법',
      '클라이언트의 움직임 분석에 따른 즉각적인 피드백 제공',
    ],
  },
  {
    subjects: ['지도자 역량 강화 프로그램'],
    lines: [
      '필라테스 동작 수행 능력, 티칭 능력, 수업 기획 능력 등 전반 평가',
      '교육과정 내 이론 및 실기 습득 수준 점검 / 평가',
      '그룹수업 구성 및 발표 실습',
      '이력서 및 자기소개서 제작 가이드',
      '시험 대비 특강 및 질의응답 세션',
      '면접 준비 및 실전 모의 면접',
    ],
  },
  {
    subjects: ['동작 수련 및 티칭 연습, 실전 실습 활동', '(필수 이수 과제)'],
    intro: '본 과정 수료를 위해 반드시 이수해야 하는 핵심 실습 과제입니다.',
    lines: [
      '기초부터 고급까지의 필수 동작군 반복 수련',
      '동작 수련 / 티칭 / 실전실습 후 수련일지(Logbook: 90%이상) 작성',
      '실제 클라이언트 대상 수업 진행 (Real Teaching Practice)',
      '실습 후 자가 체크리스트 작성으로 실전 역량 점검 및 지속적 개선 유도',
    ],
  },
  {
    subjects: ['심화과정', '(타협회 수강 가능)'],
    intro: '지도자과정 수료 후, 현직 강사로 활동하며 진행되는 심화 응용과정입니다.',
    lines: [
      '병리학 이론·실기, 말단 해부학, 특수 인구군 맞춤 시퀀스 설계',
      '정렬 기반 체형교정 실전교육 (허리, 골반, 다리, 목, 어깨, 등)',
      '정규 과정 외 심화동작 습득',
    ],
    note: "*심화과정 중 '정규과정 외 동작' 과목은 추가 교재비가 발생합니다 (별도)",
  },
];
---
<BaseLayout title="커리큘럼">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">CURRICULUM</p>
      <h1>커리큘럼</h1>
      <p class="page-hero-sub">
        필라테스 운동법의 이해력을 높이고 교육 종료 직후 트레이닝이 가능한 교육입니다.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section intro">
    <div class="wrap intro-grid">
      <div class="intro-media">
        <img src={img('6f7ec1_05b3f423d92946ffa55dabb7e6764581~mv2.jpg')} alt="KPA 지도자과정 교육생" loading="lazy" />
      </div>
      <div class="intro-copy">
        <p class="eyebrow">KPA CURRICULUM</p>
        <h2>필라테스 로직과 높은 동작완성도를 함께</h2>
        <p>
          사단법인 대한필라테스협회의 커리큘럼은 필라테스 특유의 사고력(로직) 형성과
          높은 동작완성도를 추구하며, 교육 종료 직후 실제 강사활동이 원활하도록 교육합니다.
        </p>
        <a class="btn btn--filled" href={withBase('/coursedate')}>교육일정 · 비용 안내</a>
      </div>
    </div>
  </section>

  <!-- 차별화 교육 -->
  <section class="section features">
    <div class="wrap">
      <p class="eyebrow">WHY KPA</p>
      <h2 class="features-title">사단법인 대한필라테스협회만의 차별화 교육</h2>
      <div class="feature-list">
        {features.map((f) => (
          <article class="feature">
            <div class="feature-head">
              <span class="feature-no">{f.no}</span>
              <h3>{f.title}</h3>
            </div>
            <div class="feature-body">
              <p>{f.body}</p>
              {f.hours && (
                <div class="hours-box">
                  <p class="hours-title">{f.hours.title}</p>
                  <ul>
                    {f.hours.items.map((it) => <li>{it}</li>)}
                  </ul>
                </div>
              )}
              {f.image && (
                <img class="feature-img" src={img(f.image)} alt={f.imageAlt} loading="lazy" />
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 교육 현장 사진 밴드 -->
  <section class="gallery">
    <div class="wrap">
      <p class="eyebrow">ON-SITE TRAINING</p>
      <h2 class="gallery-title">이론부터 실전까지, 교육 현장</h2>
    </div>
    <div class="gallery-strip">
      {gallery.map((g) => (
        <figure>
          <img src={img(g.src)} alt={g.alt} loading="lazy" />
          <figcaption>{g.alt}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- 지도자과정 커리큘럼 -->
  <section class="section syllabus">
    <div class="wrap">
      <p class="eyebrow">SYLLABUS</p>
      <h2 class="syllabus-title">지도자과정 커리큘럼</h2>
      <div class="cur-table">
        <div class="cur-thead">
          <span>과목</span>
          <span>교육 내용</span>
        </div>
        {curriculum.map((row) => (
          <div class="cur-row">
            <div class="cur-subject">
              {row.subjects.map((s) => <p>{s}</p>)}
            </div>
            <div class="cur-detail">
              {row.intro && <p class="cur-intro">{row.intro}</p>}
              <ul>
                {row.lines.map((l) => <li>{l}</li>)}
              </ul>
              {row.note && <p class="cur-note">{row.note}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section curriculum-cta">
    <div class="wrap">
      <h2>지금 지도자과정을 시작하세요</h2>
      <p>교육 개강 일정과 비용을 확인하고, 궁금한 점은 카카오톡으로 상담하세요.</p>
      <div class="curriculum-cta-btns">
        <a class="btn btn--filled" href={withBase('/category/all-products')}>교육 신청하기</a>
        <a class="btn" href={withBase('/coursedate')}>교육 개강 일정</a>
        <a class="btn" href={kakaoChat} target="_blank" rel="noopener">카카오톡 상담</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--kp-maroon);
    color: #fff;
    text-align: center;
    padding-block: clamp(70px, 12vw, 130px);
  }
  .page-hero .eyebrow { color: var(--kp-cream); }
  .page-hero h1 { color: #fff; font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .page-hero-sub {
    color: var(--kp-pink);
    font-size: clamp(15px, 2vw, 19px);
    margin-top: 16px;
    max-width: 720px;
    margin-inline: auto;
  }

  /* INTRO */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .intro-media img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 10px;
    display: block;
  }
  .intro-copy h2 { color: var(--kp-maroon); font-size: clamp(24px, 3.4vw, 34px); margin: 6px 0 18px; }
  .intro-copy p { color: var(--kp-olive); font-size: clamp(15px, 1.8vw, 17px); line-height: 1.85; margin-bottom: 28px; }

  /* FEATURES */
  .features { background: var(--kp-cream); }
  .features-title { color: var(--kp-maroon); font-size: clamp(24px, 3.6vw, 36px); margin: 6px 0 clamp(32px, 5vw, 56px); }
  .feature-list { display: flex; flex-direction: column; gap: clamp(28px, 4vw, 44px); }
  .feature {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: clamp(20px, 4vw, 56px);
