---
import { navGroups, siteMeta } from '../data/nav.js';
import { withBase } from '../utils/url.js';
const { pathname } = Astro.url;
const isActive = (href) => pathname === withBase(href);
---
<header class="site-header">
  <div class="wrap header-inner">
    <a class="brand" href={withBase('/')} aria-label={siteMeta.name}>
      <img src={withBase(siteMeta.logo)} alt={siteMeta.name} width="110" height="55" />
    </a>

    <nav class="primary-nav" aria-label="주 메뉴">
      <ul class="nav-list">
        {navGroups.map((group) => (
          group.children ? (
            <li class="nav-item has-children">
              <button class="nav-top" aria-haspopup="true" aria-expanded="false">
                {group.label}
                <svg class="caret" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4"/></svg>
              </button>
              <div class="dropdown">
                <ul>
                  {group.children.map((c) => (
                    <li><a href={withBase(c.href)} class={isActive(c.href) ? 'active' : ''}>{c.label}</a></li>
                  ))}
                </ul>
              </div>
            </li>
          ) : (
            <li class="nav-item">
              <a class="nav-top nav-top--link" href={withBase(group.href)}
                 target={group.external ? '_blank' : undefined}
                 rel={group.external ? 'noopener' : undefined}>{group.label}</a>
            </li>
          )
        ))}
      </ul>
    </nav>

    <div class="header-right">
      <a class="login-link" href={withBase('/members')}>로그인 <span>|</span> 회원가입</a>
      <button class="nav-toggle" aria-label="메뉴 열기" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: var(--kp-mugwort);
    color: #fff;
    box-shadow: 0 1px 0 rgba(0,0,0,0.06);
  }
  .header-inner { display: flex; align-items: center; gap: 32px; height: 78px; }
  .brand { flex-shrink: 0; }
  /* 로고를 쑥색 배경에서 흰색으로 */
  .brand img { height: 44px; width: auto; object-fit: contain; filter: brightness(0) invert(1); }

  /* ---------- Desktop nav ---------- */
  .primary-nav { flex: 1; }
  .nav-list { list-style: none; display: flex; gap: 6px; margin: 0; padding: 0; }
  .nav-item { position: relative; }
  .nav-top {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-sans); font-size: 16px; font-weight: 600;
    color: #fff; background: none; border: 0; cursor: pointer;
    padding: 12px 18px; letter-spacing: 0.01em;
  }
  .nav-top:hover, .nav-item:hover .nav-top { color: var(--kp-cream); }
  .caret { transition: transform .25s; opacity: .85; }
  .nav-item:hover .caret { transform: rotate(180deg); }

  .dropdown {
    position: absolute; top: 100%; left: 0; min-width: 210px;
    background: #fff; color: var(--kp-ink);
    box-shadow: 0 14px 30px rgba(28,16,18,0.14);
    border-top: 3px solid var(--kp-mugwort);
    opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: opacity .22s, transform .22s, visibility .22s;
  }
  .nav-item:hover .dropdown, .nav-item:focus-within .dropdown {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .dropdown ul { list-style: none; margin: 0; padding: 8px 0; }
  .dropdown a {
    display: block; padding: 11px 22px; font-size: 15px; color: var(--kp-ink);
    white-space: nowrap; transition: background .18s, color .18s, padding-left .18s;
  }
  .dropdown a:hover, .dropdown a.active {
    background: var(--kp-cream); color: var(--kp-mugwort-dark); padding-left: 28px;
  }

  /* ---------- Right ---------- */
  .header-right { display: flex; align-items: center; gap: 18px; flex-shrink: 0; }
  .login-link { font-size: 13px; color: #fff; opacity: .92; white-space: nowrap; letter-spacing: 0.02em; }
  .login-link span { opacity: .5; margin: 0 4px; }
  .login-link:hover { color: var(--kp-cream); }

  .nav-toggle {
    display: none; width: 42px; height: 42px; border: 0; background: transparent;
    flex-direction: column; justify-content: center; gap: 6px; cursor: pointer; padding: 9px;
  }
  .nav-toggle span { display: block; height: 2px; width: 100%; background: #fff; transition: transform .3s, opacity .3s; }

  /* ---------- Mobile ---------- */
  @media (max-width: 940px) {
    .header-inner { gap: 16px; }
    .primary-nav {
      position: absolute; top: 78px; left: 0; right: 0;
      background: var(--kp-mugwort);
      max-height: 0; overflow: hidden; transition: max-height .4s ease;
    }
    .primary-nav.open { max-height: 80vh; overflow-y: auto; box-shadow: 0 14px 24px rgba(0,0,0,.18); }
    .nav-list { flex-direction: column; gap: 0; padding: 6px 0; }
    .nav-item { border-top: 1px solid rgba(255,255,255,0.14); }
    .nav-top { width: 100%; justify-content: space-between; padding: 16px 24px; font-size: 17px; }
    .dropdown {
      position: static; opacity: 1; visibility: visible; transform: none;
      box-shadow: none; border-top: 0; min-width: 0;
      max-height: 0; overflow: hidden; transition: max-height .3s ease;
      background: rgba(255,255,255,0.06);
    }
    .nav-item.expanded .dropdown { max-height: 500px; }
    .nav-item:hover .dropdown { opacity: 1; } /* reset desktop rule */
    .dropdown a { color: #fff; padding: 13px 40px; }
    .dropdown a:hover, .dropdown a.active { background: rgba(0,0,0,0.12); color: var(--kp-cream); }
    .nav-item.expanded .caret { transform: rotate(180deg); }
    .nav-toggle { display: inline-flex; }
    .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const toggle = header?.querySelector('.nav-toggle');
  const nav = header?.querySelector('.primary-nav');

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
  });

  // 모바일: 카테고리 클릭 시 하위 메뉴 펼치기 (데스크톱은 hover라 무시됨)
  header?.querySelectorAll('.has-children > .nav-top').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      if (window.matchMedia('(max-width: 940px)').matches) {
        e.preventDefault();
        btn.parentElement?.classList.toggle('expanded');
        const exp = btn.parentElement?.classList.contains('expanded');
        btn.setAttribute('aria-expanded', exp ? 'true' : 'false');
      }
    });
  });
</script>
